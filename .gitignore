# environment variables
.env
.env.production

# node dependencies (PoC計測スクリプト用に一時インストール)
node_modules/

# build output
dist/

# jpoke (別リポジトリ) から毎回のビルドで再生成するマスタデータ (scripts/build-master-data)
public/master-data/

# vendor/jpoke は src/ 一式をコミット対象として同梱するが、`python -m build` (wheel化) や
# import 実行 (extract_autocomplete.py) がその場で生成する副産物はビルドのたびに再生成
# されるためコミットしない。
vendor/jpoke/build/
vendor/jpoke/src/*.egg-info/
vendor/jpoke/**/__pycache__/

# generated types
.astro/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example

# wrangler が生成する Env 型定義(実行環境依存のため通常コミットしない)
worker-configuration.d.ts

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# macOS-specific files
.DS_Store
