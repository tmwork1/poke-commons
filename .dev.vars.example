# Cloudflare Workers ローカル開発用環境変数テンプレート (`wrangler dev` が読み込む .dev.vars)
# `.env.example` と同内容。実際に使う際はコピーして `.dev.vars` を作成する:
#   cp .dev.vars.example .dev.vars
# ローカル Supabase / Postgres 接続設定
# Supabase CLI (`supabase start`) のローカルエミュレータがデフォルトポートで動作している想定

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# Postgres 直接接続 (マイグレーションランナー scripts/db/run-migrations.mjs 用)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# 匿名セッション識別子 (session_hash) を生成するためのソルト
# 日替わりでローテーションさせ長期追跡を不可能にする (開発プラン §2.4 匿名化ポリシー)
# 本番では `wrangler secret put SESSION_HASH_SECRET` で設定する
SESSION_HASH_SECRET=your_session_hash_secret_here

# 管理系API（書き込み系の運用操作など）を保護するBasic認証の資格情報
# 本番では wrangler secret put ADMIN_USERNAME / ADMIN_PASSWORD で設定する
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_admin_password_here

# 計算エンジン (jpoke) はブラウザ内 Pyodide でクライアント実行する(開発プラン §2.2 案B採用)。
# 専用 Worker・Service Binding は使わないため、ここに関連する環境変数は不要
