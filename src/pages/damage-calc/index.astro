---
// Phase 2-2: 本番用ダメージ計算 UI。
// Phase 2-4: 「よく比較される育成 / 人気の仮想敵」表示枠(当面は suggestions テーブルが
// 空のため空状態を表示するだけの枠)。
//
// 設計方針は damage-calc-poc/index.astro (Phase 1-7 検証ページ) を踏襲する:
//   - このページ自体は SSR のプレースホルダー(静的な選択肢リストの描画のみ)。
//   - Pyodide / jpoke まわりの処理はすべて下部の <script> (ブラウザ専用) に閉じ込める。
//   - Pyodide の初期化はページ読み込み時ではなく「計算エンジンを読み込む」ボタン操作まで遅延させる。
// src/lib/pyodide-engine.ts はここ以外から import しないこと
// (SSR環境には window/document が無く、読み込んだ瞬間に失敗する)。

// 性格一覧 (vendor/jpoke/src/jpoke/data/nature.py の NATURE_MODIFIER キー一覧と同期させること)
const NATURES = [
	"まじめ", "さみしがり", "いじっぱり", "やんちゃ", "ゆうかん",
	"ずぶとい", "わんぱく", "のうてんき", "のんき",
	"ひかえめ", "おっとり", "うっかりや", "れいせい",
	"おだやか", "おとなしい", "しんちょう", "なまいき",
	"おくびょう", "せっかち", "ようき", "むじゃき",
	"てれや", "がんばりや", "すなお", "きまぐれ",
];

// テラスタイプ一覧 (vendor/jpoke/src/jpoke/types/literals.py の Type リテラルと同期させること。空文字列=なし は別途先頭に追加)
const TERA_TYPES = [
	"ノーマル", "ほのお", "みず", "でんき", "くさ", "こおり", "かくとう", "どく", "じめん",
	"ひこう", "エスパー", "むし", "いわ", "ゴースト", "ドラゴン", "あく", "はがね", "フェアリー", "ステラ",
];

// 天候一覧 (vendor/jpoke/src/jpoke/types/weather.py の WeatherName と同期させること)
const WEATHERS = [
	{ value: "", label: "なし" },
	{ value: "はれ", label: "はれ" },
	{ value: "あめ", label: "あめ" },
	{ value: "すなあらし", label: "すなあらし" },
	{ value: "ゆき", label: "ゆき" },
	{ value: "おおひでり", label: "おおひでり" },
	{ value: "おおあめ", label: "おおあめ" },
	{ value: "らんきりゅう", label: "らんきりゅう" },
];

// 地形一覧 (vendor/jpoke/src/jpoke/types/terrain.py の TerrainName と同期させること)
const TERRAINS = [
	{ value: "", label: "なし" },
	{ value: "エレキフィールド", label: "エレキフィールド" },
	{ value: "グラスフィールド", label: "グラスフィールド" },
	{ value: "サイコフィールド", label: "サイコフィールド" },
	{ value: "ミストフィールド", label: "ミストフィールド" },
];

// 防御側に発動させられる壁の一覧 (下部 <script> 内の SIDE_FIELD_NAMES と同じ並び・内容に保つこと)
const SIDE_FIELDS = ["リフレクター", "ひかりのかべ", "オーロラベール"];

const STAT_LABELS: Array<{ key: string; label: string }> = [
	{ key: "hp", label: "HP" },
	{ key: "atk", label: "攻撃" },
	{ key: "def", label: "防御" },
	{ key: "spa", label: "特攻" },
	{ key: "spd", label: "特防" },
	{ key: "spe", label: "素早さ" },
];

const SIDES: Array<{ prefix: "atk" | "def"; label: string }> = [
	{ prefix: "atk", label: "攻撃側" },
	{ prefix: "def", label: "防御側" },
];
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>ダメージ計算 | Poke-Commons</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 960px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			h3 { font-size: 1rem; margin-bottom: 0.3rem; }
			section {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 1rem;
				margin: 1rem 0;
			}
			fieldset {
				border: 1px solid #ddd;
				border-radius: 6px;
				padding: 0.8rem;
				margin: 0;
			}
			.sides {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			@media (max-width: 640px) {
				.sides { grid-template-columns: 1fr; }
			}
			label { display: inline-block; min-width: 6em; }
			.row { margin: 0.5rem 0; }
			input[type="text"], input[type="number"], select {
				padding: 0.3em 0.5em;
			}
			input[type="text"] { min-width: 12em; }
			.stat-grid-label { display: block; font-size: 0.9em; color: #555; margin-bottom: 0.2rem; }
			.stat-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.stat-input {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				font-size: 0.85em;
				min-width: 0;
			}
			.stat-input input { width: 4.5em; }
			.checkbox-label { min-width: auto; margin-right: 1rem; font-weight: normal; }
			button {
				padding: 0.5em 1.2em;
				font-size: 1rem;
				cursor: pointer;
			}
			button:disabled { cursor: not-allowed; opacity: 0.6; }
			#engine-status { font-weight: bold; }
			#engine-status[data-state="loading"] { color: #b8860b; }
			#engine-status[data-state="ready"] { color: #2e7d32; }
			#engine-status[data-state="error"] { color: #c62828; }
			.spinner {
				display: inline-block; width: 1em; height: 1em; border: 2px solid #ccc;
				border-top-color: #b8860b; border-radius: 50%; animation: spin 0.8s linear infinite;
				margin-right: 0.5em; vertical-align: -0.15em;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			#damage-rolls { columns: 2; }
			#lethal-list { list-style: none; padding-left: 0; }
			#lethal-list li { padding: 0.15em 0; }
			.suggestion-block { margin: 0.8rem 0; }
			.suggestion-empty { color: #666; font-style: italic; }
			#calc-log { font-size: 0.85em; color: #666; }
		</style>
	</head>
	<body>
		<h1>ダメージ計算</h1>
		<p>
			<a href="/">トップへ戻る</a>
		</p>

		<section>
			<h2>1. 計算エンジンの読み込み</h2>
			<p>
				<button id="init-button" type="button">計算エンジンを読み込む</button>
			</p>
			<p id="engine-status" data-state="idle">未初期化(ボタンを押すまでPyodideはロードされません)</p>
		</section>

		<section>
			<h2>2. 育成入力</h2>
			<div class="sides">
				{SIDES.map(({ prefix, label }) => (
					<fieldset>
						<legend>{label}</legend>
						<div class="row">
							<label for={`${prefix}-name`}>ポケモン名</label>
							<input id={`${prefix}-name`} type="text" list="pokemon-list" autocomplete="off" />
						</div>
						<div class="row">
							<label for={`${prefix}-nature`}>性格</label>
							<select id={`${prefix}-nature`}>
								{NATURES.map((n) => <option value={n}>{n}</option>)}
							</select>
						</div>
						<div class="row">
							<label for={`${prefix}-ability`}>特性</label>
							<input id={`${prefix}-ability`} type="text" list="ability-list" autocomplete="off" />
						</div>
						<div class="row">
							<label for={`${prefix}-item`}>持ち物</label>
							<input id={`${prefix}-item`} type="text" list="item-list" autocomplete="off" />
						</div>
						<div class="row">
							<label for={`${prefix}-tera`}>テラスタイプ</label>
							<select id={`${prefix}-tera`}>
								<option value="">なし</option>
								{TERA_TYPES.map((t) => <option value={t}>{t}</option>)}
							</select>
						</div>
						{prefix === "atk" && (
							<div class="row">
								<label for="move-name">使用技</label>
								<input id="move-name" type="text" list="move-list" autocomplete="off" />
							</div>
						)}
						<div class="row stat-grid">
							<span class="stat-grid-label">努力値(0〜32)</span>
							<div class="stat-inputs">
								{STAT_LABELS.map(({ key, label: statLabel }) => (
									<label class="stat-input">
										{statLabel}
										<input id={`${prefix}-ev-${key}`} type="number" min="0" max="32" step="1" value="0" />
									</label>
								))}
							</div>
						</div>
						<div class="row stat-grid">
							<span class="stat-grid-label">個体値(省略可・既定31)</span>
							<div class="stat-inputs">
								{STAT_LABELS.map(({ key, label: statLabel }) => (
									<label class="stat-input">
										{statLabel}
										<input id={`${prefix}-iv-${key}`} type="number" min="0" max="31" step="1" placeholder="31" />
									</label>
								))}
							</div>
						</div>
					</fieldset>
				))}
			</div>
			<datalist id="pokemon-list"></datalist>
			<datalist id="move-list"></datalist>
			<datalist id="ability-list"></datalist>
			<datalist id="item-list"></datalist>
		</section>

		<section>
			<h2>3. フィールド状態</h2>
			<div class="row">
				<label for="weather">天候</label>
				<select id="weather">
					{WEATHERS.map(({ value, label }) => <option value={value}>{label}</option>)}
				</select>
			</div>
			<div class="row">
				<label for="terrain">地形</label>
				<select id="terrain">
					{TERRAINS.map(({ value, label }) => <option value={value}>{label}</option>)}
				</select>
			</div>
			<div class="row">
				<span>防御側の壁</span>
				{SIDE_FIELDS.map((name) => (
					<label class="checkbox-label">
						<input type="checkbox" id={`side-field-${name}`} value={name} />
						{name}
					</label>
				))}
			</div>
			<div class="row">
				<label for="seed">乱数シード(任意)</label>
				<input id="seed" type="number" />
			</div>
			<div class="row">
				<label for="critical" class="checkbox-label">
					<input type="checkbox" id="critical" />
					急所固定で計算する
				</label>
			</div>
		</section>

		<section>
			<h2>4. 計算結果</h2>
			<p>
				<button id="calc-button" type="button" disabled>計算する</button>
			</p>
			<p id="result-summary">(計算前)</p>
			<h3>乱数16段階のダメージ</h3>
			<ol id="damage-rolls"></ol>
			<h3>致死率</h3>
			<ul id="lethal-list"></ul>
			<p id="calc-log"></p>
		</section>

		<section>
			<h2>5. 集合知(みんなのデータから)</h2>
			<p>計算するほどデータが育ちます。Phase 5 で集計バッチが動き始めると、ここに傾向が表示されます。</p>
			<div class="suggestion-block">
				<h3>よく比較される育成</h3>
				<div id="popular-builds">読み込み中...</div>
			</div>
			<div class="suggestion-block">
				<h3>人気の仮想敵</h3>
				<div id="common-opponents">読み込み中...</div>
			</div>
		</section>

		<script>
			import {
				initEngine,
				calcDamages,
				isEngineReady,
				registerOfflineCache,
				type EngineProgress,
				type PokemonSpec,
				type FieldSpec,
				type CalcDamagesResult,
			} from "../../lib/pyodide-engine";

			type Side = "atk" | "def";
			const STAT_KEYS = ["hp", "atk", "def", "spa", "spd", "spe"] as const;

			// フィールド上部の SIDE_FIELDS (Astroフロントマター、SSR側) と同じ並び・内容を保つこと。
			// <script> はブラウザにのみバンドルされフロントマターの値を直接参照できないため、
			// ここに複製している(要素はjpoke側の壁3種で固定・変化頻度が低いため許容)。
			const SIDE_FIELD_NAMES = ["リフレクター", "ひかりのかべ", "オーロラベール"];

			function el<T extends HTMLElement>(id: string): T {
				const found = document.getElementById(id);
				if (!found) {
					throw new Error(`要素が見つかりません: #${id}`);
				}
				return found as T;
			}

			const initButton = el<HTMLButtonElement>("init-button");
			const calcButton = el<HTMLButtonElement>("calc-button");
			const statusEl = el<HTMLElement>("engine-status");
			const resultSummaryEl = el<HTMLElement>("result-summary");
			const damageRollsEl = el<HTMLOListElement>("damage-rolls");
			const lethalListEl = el<HTMLUListElement>("lethal-list");
			const calcLogEl = el<HTMLElement>("calc-log");
			const popularBuildsEl = el<HTMLElement>("popular-builds");
			const commonOpponentsEl = el<HTMLElement>("common-opponents");
			const atkNameInput = el<HTMLInputElement>("atk-name");

			function renderProgress(progress: EngineProgress) {
				statusEl.dataset.state = progress.status;
				const spinner = progress.status === "loading" ? '<span class="spinner"></span>' : "";
				statusEl.innerHTML = spinner + progress.message;
				calcButton.disabled = progress.status !== "ready";
				initButton.disabled = progress.status === "loading" || progress.status === "ready";
			}

			// --- オートコンプリート用の軽量JSON(build:master-data 生成物)を datalist に反映 ---
			async function loadAutocomplete() {
				try {
					const [pokemonRes, moveRes, abilityRes, itemRes] = await Promise.all([
						fetch("/master-data/autocomplete/pokemon.json"),
						fetch("/master-data/autocomplete/moves.json"),
						fetch("/master-data/autocomplete/abilities.json"),
						fetch("/master-data/autocomplete/items.json"),
					]);
					const fillDatalist = async (
						res: Response,
						datalistId: string,
					): Promise<void> => {
						const list = (await res.json()) as Array<{ name: string }>;
						const datalist = el<HTMLDataListElement>(datalistId);
						const fragment = document.createDocumentFragment();
						for (const { name } of list) {
							const option = document.createElement("option");
							option.value = name;
							fragment.appendChild(option);
						}
						datalist.appendChild(fragment);
					};
					await Promise.all([
						fillDatalist(pokemonRes, "pokemon-list"),
						fillDatalist(moveRes, "move-list"),
						fillDatalist(abilityRes, "ability-list"),
						fillDatalist(itemRes, "item-list"),
					]);
				} catch (err) {
					console.warn("オートコンプリート用データの読み込みに失敗しました", err);
				}
			}

			// --- フォーム値の読み取り ---
			function clamp(n: number, min: number, max: number): number {
				return Math.min(max, Math.max(min, Math.round(n)));
			}

			function readEv(side: Side, stat: string): number {
				const raw = Number(el<HTMLInputElement>(`${side}-ev-${stat}`).value);
				if (!Number.isFinite(raw)) return 0;
				return clamp(raw, 0, 32);
			}

			function readIv(side: Side, stat: string): number {
				const raw = el<HTMLInputElement>(`${side}-iv-${stat}`).value.trim();
				if (raw === "") return 31;
				const n = Number(raw);
				if (!Number.isFinite(n)) return 31;
				return clamp(n, 0, 31);
			}

			function buildSpec(side: Side): PokemonSpec {
				const name = el<HTMLInputElement>(`${side}-name`).value.trim();
				const nature = el<HTMLSelectElement>(`${side}-nature`).value || undefined;
				const abilityName = el<HTMLInputElement>(`${side}-ability`).value.trim() || undefined;
				const itemName = el<HTMLInputElement>(`${side}-item`).value.trim() || undefined;
				const teraType = el<HTMLSelectElement>(`${side}-tera`).value || undefined;
				const evs = STAT_KEYS.map((stat) => readEv(side, stat));
				const ivs = STAT_KEYS.map((stat) => readIv(side, stat));
				return { name, nature, abilityName, itemName, teraType, evs, ivs };
			}

			function buildField(): FieldSpec {
				const weather = el<HTMLSelectElement>("weather").value || undefined;
				const terrain = el<HTMLSelectElement>("terrain").value || undefined;
				const defenderSideFields = SIDE_FIELD_NAMES.filter(
					(name) => el<HTMLInputElement>(`side-field-${name}`).checked,
				);
				return { weather, terrain, defenderSideFields };
			}

			function readSeed(): number | undefined {
				const raw = el<HTMLInputElement>("seed").value.trim();
				if (raw === "") return undefined;
				const n = Number(raw);
				return Number.isFinite(n) ? n : undefined;
			}

			// --- 計算結果の描画 ---
			function renderResult(result: CalcDamagesResult) {
				const { damages, lethal } = result;

				if (damages.length === 0) {
					resultSummaryEl.textContent = "ダメージが計算できませんでした";
				} else {
					const min = Math.min(...damages);
					const max = Math.max(...damages);
					resultSummaryEl.textContent =
						min === max ? `ダメージ: ${min} (乱数幅なし)` : `ダメージ: ${min} 〜 ${max} (乱数16段階)`;
				}

				damageRollsEl.innerHTML = "";
				damages.forEach((dmg) => {
					const li = document.createElement("li");
					li.textContent = String(dmg);
					damageRollsEl.appendChild(li);
				});

				lethalListEl.innerHTML = "";
				if (lethal.length === 0) {
					const li = document.createElement("li");
					li.textContent = "致死率データなし";
					lethalListEl.appendChild(li);
				} else {
					lethal.forEach(({ attackCount, probability }) => {
						const li = document.createElement("li");
						li.textContent = `${attackCount}発: ${(probability * 100).toFixed(1)}%`;
						lethalListEl.appendChild(li);
					});
				}
			}

			// --- Phase 2-3連携: 計算ログの送信 (fire-and-forget。UI操作をブロックしない) ---
			function reportCalc(payload: unknown): void {
				fetch("/api/damage-calcs", {
					method: "POST",
					credentials: "same-origin",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify(payload),
				})
					.then((res) => {
						if (!res.ok) {
							console.warn(`計算ログの送信に失敗しました (status=${res.status})`);
						}
					})
					.catch((err) => {
						console.warn("計算ログの送信に失敗しました(表示には影響しません)", err);
					});
			}

			// --- Phase 2-4: サジェスト表示枠(空枠) ---
			interface SuggestionItem {
				kind: string;
				subject_key: string;
				payload: unknown;
				computed_at: string;
			}

			async function fetchSuggestions(kind: string, subjectKey: string, limit = 5): Promise<SuggestionItem[]> {
				try {
					const params = new URLSearchParams({ kind, subject_key: subjectKey, limit: String(limit) });
					const res = await fetch(`/api/suggestions?${params.toString()}`, {
						credentials: "same-origin",
					});
					if (!res.ok) {
						console.warn(`サジェスト取得に失敗しました (kind=${kind}, status=${res.status})`);
						return [];
					}
					const body = (await res.json()) as { data?: SuggestionItem[] };
					return body.data ?? [];
				} catch (err) {
					console.warn(`サジェスト取得に失敗しました (kind=${kind})`, err);
					return [];
				}
			}

			function renderSuggestionList(container: HTMLElement, items: SuggestionItem[]): void {
				container.innerHTML = "";
				if (items.length === 0) {
					const p = document.createElement("p");
					p.className = "suggestion-empty";
					p.textContent = "まだデータがありません(集合知はこれから育っていきます)";
					container.appendChild(p);
					return;
				}
				const ul = document.createElement("ul");
				for (const item of items) {
					const li = document.createElement("li");
					li.textContent = JSON.stringify(item.payload);
					ul.appendChild(li);
				}
				container.appendChild(ul);
			}

			async function loadSuggestions(subjectKey: string): Promise<void> {
				const [popularBuilds, commonOpponents] = await Promise.all([
					fetchSuggestions("popular_build", subjectKey),
					fetchSuggestions("common_opponent", subjectKey),
				]);
				renderSuggestionList(popularBuildsEl, popularBuilds);
				renderSuggestionList(commonOpponentsEl, commonOpponents);
			}

			// --- Phase 3-3: 育成ビルダーからの読み込み(?build=<share_slug>) ---
			interface BuildData {
				pokemon_name?: string | null;
				nature?: string | null;
				ability_name?: string | null;
				item_name?: string | null;
				tera_type?: string | null;
				evs?: Array<number | null> | null;
				ivs?: Array<number | null> | null;
				move_names?: Array<string | null> | null;
			}

			function applyBuildToAttacker(data: BuildData): void {
				if (data.pokemon_name != null) {
					el<HTMLInputElement>("atk-name").value = data.pokemon_name;
				}
				if (data.nature != null) {
					el<HTMLSelectElement>("atk-nature").value = data.nature;
				}
				if (data.ability_name != null) {
					el<HTMLInputElement>("atk-ability").value = data.ability_name;
				}
				if (data.item_name != null) {
					el<HTMLInputElement>("atk-item").value = data.item_name;
				}
				if (data.tera_type != null) {
					el<HTMLSelectElement>("atk-tera").value = data.tera_type;
				}
				const firstMove = data.move_names?.[0];
				if (firstMove != null) {
					el<HTMLInputElement>("move-name").value = firstMove;
				}
				STAT_KEYS.forEach((stat, i) => {
					const ev = data.evs?.[i];
					if (ev != null) {
						el<HTMLInputElement>(`atk-ev-${stat}`).value = String(ev);
					}
					const iv = data.ivs?.[i];
					if (iv != null) {
						el<HTMLInputElement>(`atk-iv-${stat}`).value = String(iv);
					}
				});
			}

			async function loadBuildFromQuery(): Promise<void> {
				const slug = new URLSearchParams(location.search).get("build");
				if (!slug) return;
				try {
					const res = await fetch(`/api/builds/${encodeURIComponent(slug)}`);
					if (!res.ok) {
						console.warn(`育成データの読み込みに失敗しました (status=${res.status})`);
						return;
					}
					const body = (await res.json()) as { data?: BuildData };
					if (!body.data) return;
					applyBuildToAttacker(body.data);
					void loadSuggestions(atkNameInput.value.trim());
				} catch (err) {
					console.warn("育成データの読み込みに失敗しました", err);
				}
			}

			// --- イベント配線 ---
			initButton.addEventListener("click", () => {
				// ここが唯一のPyodide初期化トリガー。ページ読み込み時には呼ばれない。
				initEngine(renderProgress).catch((err) => {
					console.error(err);
				});
			});

			calcButton.addEventListener("click", async () => {
				if (!isEngineReady()) {
					return;
				}
				calcButton.disabled = true;
				resultSummaryEl.textContent = "計算中...";
				calcLogEl.textContent = "";
				try {
					const attackerSpec = buildSpec("atk");
					const defenderSpec = buildSpec("def");
					const moveName = el<HTMLInputElement>("move-name").value.trim();

					if (!attackerSpec.name || !defenderSpec.name || !moveName) {
						resultSummaryEl.textContent = "攻撃側/防御側のポケモン名と使用技を入力してください";
						return;
					}

					const field = buildField();
					const seed = readSeed();
					const critical = el<HTMLInputElement>("critical").checked;

					const started = performance.now();
					const result = await calcDamages(attackerSpec, defenderSpec, moveName, {
						seed,
						critical,
						field,
					});
					const elapsedMs = Math.round(performance.now() - started);

					renderResult(result);
					calcLogEl.textContent = `計算時間: ${elapsedMs}ms`;

					// Phase 2-3: 計算条件 + client_result を送信 (未検証値。集計には使わない — §2.6)
					reportCalc({
						attacker_name: attackerSpec.name,
						defender_name: defenderSpec.name,
						move_name: moveName,
						attacker_build: attackerSpec,
						defender_build: defenderSpec,
						field: { ...field, seed, critical },
						client_result: result,
					});

					// 攻撃側ポケモンに紐づくサジェストを最新の入力で再取得
					void loadSuggestions(attackerSpec.name);
				} catch (err) {
					console.error(err);
					resultSummaryEl.textContent = "エラー: " + (err instanceof Error ? err.message : String(err));
				} finally {
					calcButton.disabled = !isEngineReady();
				}
			});

			atkNameInput.addEventListener("change", () => {
				const name = atkNameInput.value.trim();
				if (name) {
					void loadSuggestions(name);
				}
			});

			renderProgress({ status: "idle", message: "未初期化(ボタンを押すまでPyodideはロードされません)" });
			void loadAutocomplete();
			void loadBuildFromQuery();
			void loadSuggestions(atkNameInput.value.trim());
			// Pyodide自体のロードは開始しない(SW登録のみ)。2回目以降の訪問で
			// pyodide.js/wheelの再ダウンロードを避けるため、ページ読み込み時に登録しておく。
			registerOfflineCache();
		</script>
	</body>
</html>
