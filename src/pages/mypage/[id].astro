---
// Phase C-3: 個体の編集フォーム (育成データ管理計画.md §6.2, §8 Phase C-3)。
// デバウンス付き即時自動保存 + 楽観的UI更新: 入力のたびに数百ms待ってから
// PUT /api/owned-pokemon/:id を呼ぶ。保存中も入力をブロックしない。失敗時のみエラー表示する。
//
// 初期表示データの取得は API 経由の fetch ではなく、Astro のフロントマター(SSR)で
// src/lib/owned-pokemon.ts の getOwnedPokemon() を直接呼び出す(mypage.astro の一覧取得のような
// クライアント側fetchより初期表示が速く、かつ「生のSupabaseクエリはowned-pokemon.tsに集約する」
// という設計原則にも合致する)。
//
// 未ログイン時、および他人の個体/存在しないIDの場合はいずれもログイン導線・見つからない旨の
// メッセージを表示するのみで、強制リダイレクトはしない(Phase A-3の方針を踏襲)。
export const prerender = false;

import { getSupabaseAdminClient } from '../../lib/supabase';
import { getOwnedPokemon, type OwnedPokemonRecord } from '../../lib/owned-pokemon';

const user = Astro.locals.user;
const id = Astro.params.id;

let pokemon: OwnedPokemonRecord | null = null;
let loadError = false;

if (user && id) {
	const supabase = await getSupabaseAdminClient();
	const result = await getOwnedPokemon(user.id, id, supabase);
	if (result.ok) {
		pokemon = result.data;
	} else {
		loadError = true;
	}
	if (!pokemon && !loadError) {
		Astro.response.status = 404;
	}
}

const NATURES = [
	"まじめ", "さみしがり", "いじっぱり", "やんちゃ", "ゆうかん",
	"ずぶとい", "わんぱく", "のうてんき", "のんき",
	"ひかえめ", "おっとり", "うっかりや", "れいせい",
	"おだやか", "おとなしい", "しんちょう", "なまいき",
	"おくびょう", "せっかち", "ようき", "むじゃき",
	"てれや", "がんばりや", "すなお", "きまぐれ",
];

const TERA_TYPES = [
	"ノーマル", "ほのお", "みず", "でんき", "くさ", "こおり", "かくとう", "どく", "じめん",
	"ひこう", "エスパー", "むし", "いわ", "ゴースト", "ドラゴン", "あく", "はがね", "フェアリー", "ステラ",
];

// Phase D-5: 対戦相手メモの計算導線用。src/pages/damage-calc/index.astro の
// WEATHERS/TERRAINS/SIDE_FIELDS と同じ選択肢を使う(jpoke側の定義と同期させること)。
const WEATHERS = [
	{ value: "", label: "なし" },
	{ value: "はれ", label: "はれ" },
	{ value: "あめ", label: "あめ" },
	{ value: "すなあらし", label: "すなあらし" },
	{ value: "ゆき", label: "ゆき" },
	{ value: "おおひでり", label: "おおひでり" },
	{ value: "おおあめ", label: "おおあめ" },
	{ value: "らんきりゅう", label: "らんきりゅう" },
];

const TERRAINS = [
	{ value: "", label: "なし" },
	{ value: "エレキフィールド", label: "エレキフィールド" },
	{ value: "グラスフィールド", label: "グラスフィールド" },
	{ value: "サイコフィールド", label: "サイコフィールド" },
	{ value: "ミストフィールド", label: "ミストフィールド" },
];

const SIDE_FIELDS = ["リフレクター", "ひかりのかべ", "オーロラベール"];

const STAT_LABELS: Array<{ key: string; label: string }> = [
	{ key: "hp", label: "HP" },
	{ key: "atk", label: "攻撃" },
	{ key: "def", label: "防御" },
	{ key: "spa", label: "特攻" },
	{ key: "spd", label: "特防" },
	{ key: "spe", label: "素早さ" },
];

const MOVE_SLOTS = [1, 2, 3, 4];

function statAt(values: number[] | undefined, index: number, fallback: number): number {
	return values && typeof values[index] === "number" ? values[index] : fallback;
}
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{pokemon ? `${pokemon.nickname ?? pokemon.species_name}を編集` : "個体編集"} | Poke-Commons</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 960px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			section {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 1rem;
				margin: 1rem 0;
			}
			fieldset {
				border: 1px solid #ddd;
				border-radius: 6px;
				padding: 0.8rem;
				margin: 0;
			}
			label { display: inline-block; min-width: 6em; }
			.row { margin: 0.5rem 0; }
			input[type="text"], input[type="number"], select, textarea {
				padding: 0.3em 0.5em;
				font: inherit;
			}
			input[type="text"] { min-width: 12em; }
			textarea { width: 100%; min-height: 4em; }
			.stat-grid-label { display: block; font-size: 0.9em; color: #555; margin-bottom: 0.2rem; }
			.stat-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.stat-input {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				font-size: 0.85em;
				min-width: 0;
			}
			.stat-input input { width: 4.5em; }
			.move-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.move-input-group { display: flex; flex-direction: column; gap: 0.2em; }
			.move-input-group a { font-size: 0.8em; }
			.pokemon-name-row { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
			#pokemon-detail-link { font-size: 0.9em; }
			#autosave-status { font-weight: bold; }
			#autosave-status[data-state="saving"] { color: #b8860b; }
			#autosave-status[data-state="saved"] { color: #2e7d32; }
			#autosave-status[data-state="error"] { color: #c62828; }
			.login-button { padding: 0.6em 1.2em; text-decoration: none; color: inherit; border: 1px solid #ccc; border-radius: 6px; }
			.delete-button { color: #c62828; padding: 0.5em 1.2em; cursor: pointer; }
			#retry-button { display: none; margin-left: 0.6em; }
			#retry-button.visible { display: inline-block; }

			/* Phase D-5: 対戦相手メモセクション */
			.checkbox-label { min-width: auto; margin-right: 1rem; font-weight: normal; }
			#opponent-notes-section button { padding: 0.4em 1em; font-size: 1rem; cursor: pointer; }
			#opponent-notes-section button:disabled { cursor: not-allowed; opacity: 0.6; }
			.opponent-note-list { list-style: none; padding-left: 0; }
			.opponent-note-item { border: 1px solid #ddd; border-radius: 6px; padding: 0.6rem 0.9rem; margin: 0.6rem 0; }
			.opponent-note-move { color: #444; }
			.opponent-note-meta { font-size: 0.85em; color: #666; margin-top: 0.2rem; }
			.opponent-note-memo-preview { margin: 0.4rem 0; color: #444; }
			.opponent-note-actions { margin-top: 0.5rem; display: flex; gap: 0.5rem; }
			.opponent-note-actions button { padding: 0.3em 0.9em; font-size: 0.9rem; }
			.opponent-note-empty { color: #666; }
			#opponent-note-form-container {
				margin-top: 1rem;
				border-top: 1px dashed #ccc;
				padding-top: 1rem;
			}
			#opponent-note-engine-status { font-weight: bold; }
			#opponent-note-engine-status[data-state="loading"] { color: #b8860b; }
			#opponent-note-engine-status[data-state="ready"] { color: #2e7d32; }
			#opponent-note-engine-status[data-state="error"] { color: #c62828; }
			.spinner {
				display: inline-block; width: 1em; height: 1em; border: 2px solid #ccc;
				border-top-color: #b8860b; border-radius: 50%; animation: spin 0.8s linear infinite;
				margin-right: 0.5em; vertical-align: -0.15em;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			#opponent-note-damage-rolls { columns: 2; }
			#opponent-note-lethal-list { list-style: none; padding-left: 0; }
			#opponent-note-lethal-list li { padding: 0.15em 0; }
			#opponent-note-form-status { font-size: 0.9em; color: #c62828; }
		</style>
	</head>
	<body>
		<h1>個体を編集</h1>
		<p><a href="/mypage">マイページへ戻る</a></p>

		{
			!user ? (
				<section>
					<p>個体を編集するにはログインが必要です。</p>
					<a class="login-button" href="/api/auth/login">Googleでログイン</a>
				</section>
			) : loadError ? (
				<section>
					<p>個体情報の取得に失敗しました。時間をおいて再度お試しください。</p>
				</section>
			) : !pokemon ? (
				<section>
					<p>指定された個体が見つかりませんでした(削除された、または他のアカウントの個体である可能性があります)。</p>
				</section>
			) : (
				<>
				<form id="edit-form" data-id={pokemon.id}>
					<section>
						<h2>基本情報</h2>
						<div class="row">
							<label for="nickname">ニックネーム</label>
							<input id="nickname" type="text" autocomplete="off" value={pokemon.nickname ?? ""} />
						</div>
						<div class="row pokemon-name-row">
							<label for="species-name">ポケモン名</label>
							<input
								id="species-name"
								type="text"
								list="pokemon-list"
								autocomplete="off"
								required
								value={pokemon.species_name}
							/>
							<a id="pokemon-detail-link" href="#" target="_blank" rel="noopener">図鑑で見る</a>
						</div>
						<div class="row">
							<label for="level">レベル</label>
							<input id="level" type="number" min="1" max="100" step="1" placeholder="未設定" value={pokemon.level ?? ""} />
						</div>
						<div class="row">
							<label for="nature">性格</label>
							<select id="nature">
								<option value="">未設定</option>
								{NATURES.map((n) => <option value={n} selected={pokemon!.nature === n}>{n}</option>)}
							</select>
						</div>
						<div class="row">
							<label for="ability">特性</label>
							<input id="ability" type="text" list="ability-list" autocomplete="off" value={pokemon.ability_name ?? ""} />
						</div>
						<div class="row">
							<label for="item">持ち物</label>
							<input id="item" type="text" list="item-list" autocomplete="off" value={pokemon.item_name ?? ""} />
						</div>
						<div class="row">
							<label for="tera">テラスタイプ</label>
							<select id="tera">
								<option value="">なし</option>
								{TERA_TYPES.map((t) => <option value={t} selected={pokemon!.tera_type === t}>{t}</option>)}
							</select>
						</div>
					</section>

					<section>
						<h2>努力値・個体値</h2>
						<fieldset>
							<div class="row stat-grid">
								<span class="stat-grid-label">努力値(0〜32)</span>
								<div class="stat-inputs">
									{STAT_LABELS.map(({ key, label: statLabel }, i) => (
										<label class="stat-input">
											{statLabel}
											<input
												id={`ev-${key}`}
												type="number"
												min="0"
												max="32"
												step="1"
												value={statAt(pokemon!.evs, i, 0)}
											/>
										</label>
									))}
								</div>
							</div>
							<div class="row stat-grid" style="margin-top: 0.8rem;">
								<span class="stat-grid-label">個体値(省略可・既定31)</span>
								<div class="stat-inputs">
									{STAT_LABELS.map(({ key, label: statLabel }, i) => (
										<label class="stat-input">
											{statLabel}
											<input
												id={`iv-${key}`}
												type="number"
												min="0"
												max="31"
												step="1"
												value={statAt(pokemon!.ivs, i, 31)}
											/>
										</label>
									))}
								</div>
							</div>
						</fieldset>
					</section>

					<section>
						<h2>技構成(最大4つ・任意)</h2>
						<div class="move-inputs">
							{MOVE_SLOTS.map((slot, i) => (
								<div class="move-input-group">
									<input
										id={`move-${slot}`}
										type="text"
										list="move-list"
										autocomplete="off"
										placeholder={`技${slot}`}
										value={pokemon!.move_names[i] ?? ""}
									/>
									<a class="move-detail-link" data-slot={slot} href="#" target="_blank" rel="noopener">技を見る</a>
								</div>
							))}
						</div>
					</section>

					<section>
						<h2>タグ・メモ</h2>
						<div class="row">
							<label for="tags">タグ</label>
							<input id="tags" type="text" placeholder="カンマ区切り(例: エース, 対面)" autocomplete="off" value={pokemon.tags.join(", ")} />
						</div>
						<div class="row">
							<label><input id="is-pinned" type="checkbox" checked={pokemon.is_pinned} /> ピン留めする</label>
						</div>
						<div class="row">
							<label for="memo">メモ</label><br />
							<textarea id="memo" rows="4">{pokemon.memo ?? ""}</textarea>
						</div>
					</section>

					<section>
						<p id="autosave-status" data-state="saved">
							<span id="autosave-status-text">保存済み</span><button id="retry-button" type="button">再試行</button>
						</p>
						<button id="delete-button" class="delete-button" type="button">この個体を削除</button>
					</section>
				</form>

				<section id="opponent-notes-section" data-owned-pokemon-id={pokemon.id}>
					<h2>対戦相手メモ</h2>
					<p>この個体を相手にダメージ計算した結果を、対戦相手ごとに記録できます。</p>
					<div id="opponent-notes-list">
						<p>読み込み中...</p>
					</div>
					<p>
						<button id="opponent-note-new-button" type="button">+ 新しいメモを追加</button>
					</p>

					<div id="opponent-note-form-container" style="display:none;">
						<h3 id="opponent-note-form-title">新しい対戦相手メモ</h3>
						<form id="opponent-note-form" data-editing-id="">
							<div class="row pokemon-name-row">
								<label for="opp-name">相手ポケモン名</label>
								<input id="opp-name" type="text" list="pokemon-list" autocomplete="off" required />
							</div>
							<div class="row">
								<label for="opp-nature">相手の性格</label>
								<select id="opp-nature">
									<option value="">未設定</option>
									{NATURES.map((n) => <option value={n}>{n}</option>)}
								</select>
							</div>
							<div class="row">
								<label for="opp-ability">相手の特性</label>
								<input id="opp-ability" type="text" list="ability-list" autocomplete="off" />
							</div>
							<div class="row">
								<label for="opp-item">相手の持ち物</label>
								<input id="opp-item" type="text" list="item-list" autocomplete="off" />
							</div>
							<div class="row">
								<label for="opp-tera">相手のテラスタイプ</label>
								<select id="opp-tera">
									<option value="">なし</option>
									{TERA_TYPES.map((t) => <option value={t}>{t}</option>)}
								</select>
							</div>
							<fieldset>
								<div class="row stat-grid">
									<span class="stat-grid-label">相手の努力値(0〜32)</span>
									<div class="stat-inputs">
										{STAT_LABELS.map(({ key, label: statLabel }) => (
											<label class="stat-input">
												{statLabel}
												<input id={`opp-ev-${key}`} type="number" min="0" max="32" step="1" value="0" />
											</label>
										))}
									</div>
								</div>
								<div class="row stat-grid" style="margin-top: 0.8rem;">
									<span class="stat-grid-label">相手の個体値(省略可・既定31)</span>
									<div class="stat-inputs">
										{STAT_LABELS.map(({ key, label: statLabel }) => (
											<label class="stat-input">
												{statLabel}
												<input id={`opp-iv-${key}`} type="number" min="0" max="31" step="1" placeholder="31" />
											</label>
										))}
									</div>
								</div>
							</fieldset>
							<div class="row">
								<label for="opp-move-name">この個体が使う技</label>
								<input id="opp-move-name" type="text" list="move-list" autocomplete="off" />
							</div>
							<div class="row">
								<label for="opp-weather">天候</label>
								<select id="opp-weather">
									{WEATHERS.map(({ value, label }) => <option value={value}>{label}</option>)}
								</select>
							</div>
							<div class="row">
								<label for="opp-terrain">地形</label>
								<select id="opp-terrain">
									{TERRAINS.map(({ value, label }) => <option value={value}>{label}</option>)}
								</select>
							</div>
							<div class="row">
								<span>相手側の壁</span>
								{SIDE_FIELDS.map((name) => (
									<label class="checkbox-label">
										<input type="checkbox" id={`opp-side-field-${name}`} value={name} />
										{name}
									</label>
								))}
							</div>
							<div class="row">
								<label for="opp-seed">乱数シード(任意)</label>
								<input id="opp-seed" type="number" />
							</div>
							<div class="row">
								<label for="opp-critical" class="checkbox-label">
									<input type="checkbox" id="opp-critical" />
									急所固定で計算する
								</label>
							</div>
							<div class="row">
								<label for="opp-memo">メモ</label><br />
								<textarea id="opp-memo" rows="3"></textarea>
							</div>

							<div class="row">
								<button id="opponent-note-init-engine-button" type="button">計算エンジンを読み込む</button>
								<span id="opponent-note-engine-status" data-state="idle">未初期化(ボタンを押すまでPyodideはロードされません)</span>
							</div>
							<div class="row">
								<button id="opponent-note-calc-button" type="button" disabled>計算する</button>
							</div>
							<p id="opponent-note-result-summary">(計算前)</p>
							<ol id="opponent-note-damage-rolls"></ol>
							<ul id="opponent-note-lethal-list"></ul>

							<div class="row">
								<button id="opponent-note-save-button" type="button">メモを保存</button>
								<button id="opponent-note-cancel-button" type="button">キャンセル</button>
							</div>
							<p id="opponent-note-form-status"></p>
						</form>
					</div>
				</section>
				</>
			)
		}

		<datalist id="pokemon-list"></datalist>
		<datalist id="move-list"></datalist>
		<datalist id="ability-list"></datalist>
		<datalist id="item-list"></datalist>

		<script>
			import {
				el,
				loadAutocomplete,
				readEv,
				readIv,
				readMoveNames,
				parseTagsInput,
				pokemonDetailHref,
				moveDetailHref,
			} from "../../lib/owned-pokemon-form";
			// Phase D-5: 対戦相手メモの計算導線。pyodide-engine.ts はブラウザ専用モジュールのため
			// 必ずこの<script>(ブラウザ専用バンドル)内でのみimportする(SSR/フロントマターからは禁止)。
			import {
				initEngine,
				calcDamages,
				isEngineReady,
				type EngineProgress,
				type PokemonSpec,
				type FieldSpec,
				type CalcDamagesResult,
			} from "../../lib/pyodide-engine";
			import type { OpponentNoteRecord } from "../../lib/opponent-notes";
			import type { OpponentBuildInput, OpponentFieldInput } from "../../lib/opponent-notes-validation";

			const form = document.getElementById("edit-form") as HTMLFormElement | null;
			if (form) {
				const STAT_KEYS = ["hp", "atk", "def", "spa", "spd", "spe"] as const;
				const ownedPokemonId = form.dataset.id ?? "";
				const speciesInput = el<HTMLInputElement>("species-name");
				const detailLink = el<HTMLAnchorElement>("pokemon-detail-link");
				const statusEl = el<HTMLElement>("autosave-status");
				const statusTextEl = el<HTMLElement>("autosave-status-text");
				const retryButton = el<HTMLButtonElement>("retry-button");
				const deleteButton = el<HTMLButtonElement>("delete-button");

				function updateDetailLink(): void {
					const name = speciesInput.value.trim();
					if (name === "") {
						detailLink.style.visibility = "hidden";
						return;
					}
					detailLink.style.visibility = "visible";
					detailLink.href = pokemonDetailHref(name);
				}
				speciesInput.addEventListener("input", updateDetailLink);
				updateDetailLink();

				for (const link of document.querySelectorAll<HTMLAnchorElement>(".move-detail-link")) {
					const slot = link.dataset.slot;
					const input = slot ? document.getElementById(`move-${slot}`) as HTMLInputElement | null : null;
					if (!input) continue;
					const update = () => {
						const name = input.value.trim();
						if (name === "") {
							link.style.visibility = "hidden";
							return;
						}
						link.style.visibility = "visible";
						link.href = moveDetailHref(name);
					};
					input.addEventListener("input", update);
					update();
				}

				function readLevel(): number | null {
					const raw = el<HTMLInputElement>("level").value.trim();
					if (raw === "") return null;
					const n = Number(raw);
					if (!Number.isFinite(n)) return null;
					return Math.min(100, Math.max(1, Math.round(n)));
				}

				function buildPayload() {
					return {
						nickname: el<HTMLInputElement>("nickname").value.trim(),
						species_name: speciesInput.value.trim(),
						level: readLevel(),
						nature: el<HTMLSelectElement>("nature").value,
						ability_name: el<HTMLInputElement>("ability").value.trim(),
						item_name: el<HTMLInputElement>("item").value.trim(),
						tera_type: el<HTMLSelectElement>("tera").value,
						evs: STAT_KEYS.map((k) => readEv(k)),
						ivs: STAT_KEYS.map((k) => readIv(k)),
						move_names: readMoveNames(),
						memo: el<HTMLTextAreaElement>("memo").value.trim(),
						tags: parseTagsInput(el<HTMLInputElement>("tags").value),
						is_pinned: el<HTMLInputElement>("is-pinned").checked,
					};
				}

				// デバウンス付き即時自動保存 + 楽観的UI更新(計画書§6.2)。
				// 入力のたびに保存を試みるが、保存中/失敗中でも入力そのものはブロックしない。
				const DEBOUNCE_MS = 700;
				let debounceTimer: ReturnType<typeof setTimeout> | undefined;
				let saving = false;
				let pendingRetry = false;

				async function saveNow(): Promise<void> {
					if (saving) {
						pendingRetry = true;
						return;
					}
					const payload = buildPayload();
					saving = true;
					statusEl.dataset.state = "saving";
					statusTextEl.textContent = "保存中...";
					retryButton.classList.remove("visible");

					try {
						const res = await fetch(`/api/owned-pokemon/${encodeURIComponent(ownedPokemonId)}`, {
							method: "PUT",
							credentials: "same-origin",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify(payload),
						});
						if (!res.ok) {
							const body = (await res.json().catch(() => ({}))) as { error?: string };
							throw new Error(body.error ?? `保存に失敗しました (status=${res.status})`);
						}
						statusEl.dataset.state = "saved";
						statusTextEl.textContent = "保存済み";
					} catch (err) {
						console.error(err);
						statusEl.dataset.state = "error";
						statusTextEl.textContent = "保存に失敗しました。";
						retryButton.classList.add("visible");
					} finally {
						saving = false;
						if (pendingRetry) {
							pendingRetry = false;
							void saveNow();
						}
					}
				}

				function scheduleSave(): void {
					statusEl.dataset.state = "saving";
					statusTextEl.textContent = "編集中...";
					retryButton.classList.remove("visible");
					if (debounceTimer) clearTimeout(debounceTimer);
					debounceTimer = setTimeout(() => {
						void saveNow();
					}, DEBOUNCE_MS);
				}

				retryButton.addEventListener("click", () => {
					void saveNow();
				});

				const textInputIds = ["nickname", "species-name", "level", "ability", "item", "tags", "memo", ...STAT_KEYS.map((k) => `ev-${k}`), ...STAT_KEYS.map((k) => `iv-${k}`), "move-1", "move-2", "move-3", "move-4"];
				for (const id of textInputIds) {
					const target = document.getElementById(id);
					if (!target) continue;
					target.addEventListener("input", scheduleSave);
				}
				const changeInputIds = ["nature", "tera", "is-pinned"];
				for (const id of changeInputIds) {
					const target = document.getElementById(id);
					if (!target) continue;
					target.addEventListener("change", scheduleSave);
				}

				deleteButton.addEventListener("click", () => {
					void (async () => {
						if (!window.confirm("この個体を削除します。よろしいですか?")) return;
						deleteButton.disabled = true;
						try {
							const res = await fetch(`/api/owned-pokemon/${encodeURIComponent(ownedPokemonId)}`, {
								method: "DELETE",
								credentials: "same-origin",
							});
							if (!res.ok) throw new Error(`削除に失敗しました (status=${res.status})`);
							window.location.href = "/mypage";
						} catch (err) {
							console.error(err);
							window.alert("削除に失敗しました。時間をおいて再度お試しください。");
							deleteButton.disabled = false;
						}
					})();
				});

				// --- Phase D-5: 対戦相手メモ(一覧・追加・編集・削除・Pyodide計算導線) ---
				const opponentNotesSection = document.getElementById("opponent-notes-section");
				if (opponentNotesSection) {
					const OPP_SIDE_FIELD_NAMES = ["リフレクター", "ひかりのかべ", "オーロラベール"];

					const notesListEl = el<HTMLElement>("opponent-notes-list");
					const newNoteButton = el<HTMLButtonElement>("opponent-note-new-button");
					const noteFormContainer = el<HTMLElement>("opponent-note-form-container");
					const noteForm = el<HTMLFormElement>("opponent-note-form");
					const noteFormTitle = el<HTMLElement>("opponent-note-form-title");
					const cancelNoteButton = el<HTMLButtonElement>("opponent-note-cancel-button");
					const saveNoteButton = el<HTMLButtonElement>("opponent-note-save-button");
					const noteFormStatusEl = el<HTMLElement>("opponent-note-form-status");
					const engineInitButton = el<HTMLButtonElement>("opponent-note-init-engine-button");
					const engineStatusEl = el<HTMLElement>("opponent-note-engine-status");
					const noteCalcButton = el<HTMLButtonElement>("opponent-note-calc-button");
					const noteResultSummaryEl = el<HTMLElement>("opponent-note-result-summary");
					const noteDamageRollsEl = el<HTMLOListElement>("opponent-note-damage-rolls");
					const noteLethalListEl = el<HTMLUListElement>("opponent-note-lethal-list");

					// この個体(攻撃側)が現在フォームに入力している値からPokemonSpecを組み立てる
					// (計画書の指示どおり、個体の現在値をそのまま使う。DBへの保存有無に関わらず
					// 画面上の最新入力を使うことで、保存前の一時的な確認にも使えるようにする)。
					function buildAttackerSpec(): PokemonSpec {
						return {
							name: speciesInput.value.trim(),
							nature: el<HTMLSelectElement>("nature").value || undefined,
							abilityName: el<HTMLInputElement>("ability").value.trim() || undefined,
							itemName: el<HTMLInputElement>("item").value.trim() || undefined,
							teraType: el<HTMLSelectElement>("tera").value || undefined,
							evs: STAT_KEYS.map((k) => readEv(k)),
							ivs: STAT_KEYS.map((k) => readIv(k)),
							moveNames: readMoveNames(),
						};
					}

					function clampNum(n: number, min: number, max: number): number {
						return Math.min(max, Math.max(min, Math.round(n)));
					}

					function readOppEv(stat: string): number {
						const raw = Number(el<HTMLInputElement>(`opp-ev-${stat}`).value);
						if (!Number.isFinite(raw)) return 0;
						return clampNum(raw, 0, 32);
					}

					function readOppIv(stat: string): number {
						const raw = el<HTMLInputElement>(`opp-iv-${stat}`).value.trim();
						if (raw === "") return 31;
						const n = Number(raw);
						if (!Number.isFinite(n)) return 31;
						return clampNum(n, 0, 31);
					}

					function buildOpponentBuild(): OpponentBuildInput {
						return {
							name: el<HTMLInputElement>("opp-name").value.trim(),
							nature: el<HTMLSelectElement>("opp-nature").value || undefined,
							abilityName: el<HTMLInputElement>("opp-ability").value.trim() || undefined,
							itemName: el<HTMLInputElement>("opp-item").value.trim() || undefined,
							teraType: el<HTMLSelectElement>("opp-tera").value || undefined,
							evs: STAT_KEYS.map((k) => readOppEv(k)),
							ivs: STAT_KEYS.map((k) => readOppIv(k)),
						};
					}

					function buildOpponentField(): OpponentFieldInput {
						const weather = el<HTMLSelectElement>("opp-weather").value || undefined;
						const terrain = el<HTMLSelectElement>("opp-terrain").value || undefined;
						const defenderSideFields = OPP_SIDE_FIELD_NAMES.filter(
							(name) => el<HTMLInputElement>(`opp-side-field-${name}`).checked,
						);
						const critical = el<HTMLInputElement>("opp-critical").checked;
						const result: OpponentFieldInput = { weather, terrain, defenderSideFields };
						const seedRaw = el<HTMLInputElement>("opp-seed").value.trim();
						if (seedRaw !== "") {
							const n = Number(seedRaw);
							if (Number.isFinite(n)) result.seed = Math.round(n);
						}
						if (critical) result.critical = true;
						return result;
					}

					// --- Pyodide計算エンジン(遅延初期化、ボタン操作のみがトリガー) ---
					function renderEngineProgress(progress: EngineProgress): void {
						engineStatusEl.dataset.state = progress.status;
						const spinner = progress.status === "loading" ? '<span class="spinner"></span>' : "";
						engineStatusEl.innerHTML = spinner + progress.message;
						noteCalcButton.disabled = progress.status !== "ready";
						engineInitButton.disabled = progress.status === "loading" || progress.status === "ready";
					}

					engineInitButton.addEventListener("click", () => {
						initEngine(renderEngineProgress).catch((err) => {
							console.error(err);
						});
					});

					function clearNoteResultDisplay(): void {
						noteResultSummaryEl.textContent = "(計算前)";
						noteDamageRollsEl.innerHTML = "";
						noteLethalListEl.innerHTML = "";
					}

					function renderNoteResult(result: CalcDamagesResult): void {
						const { damages, lethal } = result;
						if (damages.length === 0) {
							noteResultSummaryEl.textContent = "ダメージが計算できませんでした";
						} else {
							const min = Math.min(...damages);
							const max = Math.max(...damages);
							noteResultSummaryEl.textContent =
								min === max ? `ダメージ: ${min} (乱数幅なし)` : `ダメージ: ${min} 〜 ${max} (乱数16段階)`;
						}
						noteDamageRollsEl.innerHTML = "";
						damages.forEach((dmg) => {
							const li = document.createElement("li");
							li.textContent = String(dmg);
							noteDamageRollsEl.appendChild(li);
						});
						noteLethalListEl.innerHTML = "";
						if (lethal.length === 0) {
							const li = document.createElement("li");
							li.textContent = "致死率データなし";
							noteLethalListEl.appendChild(li);
						} else {
							lethal.forEach(({ attackCount, probability }) => {
								const li = document.createElement("li");
								li.textContent = `${attackCount}発: ${(probability * 100).toFixed(1)}%`;
								noteLethalListEl.appendChild(li);
							});
						}
					}

					// 保存対象として保持する直近の計算結果(計算しないまま保存すればnullのまま送る)。
					let lastClientResult: CalcDamagesResult | null = null;

					noteCalcButton.addEventListener("click", () => {
						void (async () => {
							if (!isEngineReady()) return;
							noteCalcButton.disabled = true;
							noteResultSummaryEl.textContent = "計算中...";
							try {
								const attackerSpec = buildAttackerSpec();
								const defenderSpec = buildOpponentBuild();
								const moveName = el<HTMLInputElement>("opp-move-name").value.trim();
								if (!attackerSpec.name || !defenderSpec.name || !moveName) {
									noteResultSummaryEl.textContent = "この個体/相手のポケモン名と使用技を入力してください";
									return;
								}
								const field = buildOpponentField();
								const result = await calcDamages(attackerSpec, defenderSpec as PokemonSpec, moveName, {
									seed: field.seed,
									critical: field.critical ?? false,
									field: field as FieldSpec,
								});
								lastClientResult = result;
								renderNoteResult(result);
							} catch (err) {
								console.error(err);
								noteResultSummaryEl.textContent = "エラー: " + (err instanceof Error ? err.message : String(err));
							} finally {
								noteCalcButton.disabled = !isEngineReady();
							}
						})();
					});

					// --- 追加/編集フォームの開閉 ---
					function resetNoteForm(): void {
						noteForm.dataset.editingId = "";
						el<HTMLInputElement>("opp-name").value = "";
						el<HTMLSelectElement>("opp-nature").value = "";
						el<HTMLInputElement>("opp-ability").value = "";
						el<HTMLInputElement>("opp-item").value = "";
						el<HTMLSelectElement>("opp-tera").value = "";
						STAT_KEYS.forEach((k) => {
							el<HTMLInputElement>(`opp-ev-${k}`).value = "0";
							el<HTMLInputElement>(`opp-iv-${k}`).value = "";
						});
						el<HTMLInputElement>("opp-move-name").value = "";
						el<HTMLSelectElement>("opp-weather").value = "";
						el<HTMLSelectElement>("opp-terrain").value = "";
						for (const name of OPP_SIDE_FIELD_NAMES) {
							el<HTMLInputElement>(`opp-side-field-${name}`).checked = false;
						}
						el<HTMLInputElement>("opp-seed").value = "";
						el<HTMLInputElement>("opp-critical").checked = false;
						el<HTMLTextAreaElement>("opp-memo").value = "";
						lastClientResult = null;
						clearNoteResultDisplay();
						noteFormStatusEl.textContent = "";
					}

					function openFormForNew(): void {
						resetNoteForm();
						noteFormTitle.textContent = "新しい対戦相手メモ";
						noteFormContainer.style.display = "block";
						noteFormContainer.scrollIntoView({ behavior: "smooth", block: "nearest" });
					}

					function openFormForEdit(note: OpponentNoteRecord): void {
						resetNoteForm();
						noteForm.dataset.editingId = note.id;
						// note.opponent_build/field は保存時にサーバー側で検証済みの
						// OpponentBuildInput/OpponentFieldInput形状のJSONだが、DB上はRecord<string, unknown>
						// 型のため、フォームへの読み込み時のみこの形状であるとみなして読む。
						const build = note.opponent_build as unknown as OpponentBuildInput;
						const field = note.field as unknown as OpponentFieldInput;
						el<HTMLInputElement>("opp-name").value = build.name ?? "";
						el<HTMLSelectElement>("opp-nature").value = build.nature ?? "";
						el<HTMLInputElement>("opp-ability").value = build.abilityName ?? "";
						el<HTMLInputElement>("opp-item").value = build.itemName ?? "";
						el<HTMLSelectElement>("opp-tera").value = build.teraType ?? "";
						STAT_KEYS.forEach((k, i) => {
							el<HTMLInputElement>(`opp-ev-${k}`).value = String(build.evs?.[i] ?? 0);
							el<HTMLInputElement>(`opp-iv-${k}`).value = build.ivs?.[i] != null ? String(build.ivs[i]) : "";
						});
						el<HTMLInputElement>("opp-move-name").value = note.move_name ?? "";
						el<HTMLSelectElement>("opp-weather").value = field.weather ?? "";
						el<HTMLSelectElement>("opp-terrain").value = field.terrain ?? "";
						for (const name of OPP_SIDE_FIELD_NAMES) {
							el<HTMLInputElement>(`opp-side-field-${name}`).checked = (field.defenderSideFields ?? []).includes(name);
						}
						el<HTMLInputElement>("opp-seed").value = field.seed != null ? String(field.seed) : "";
						el<HTMLInputElement>("opp-critical").checked = field.critical ?? false;
						el<HTMLTextAreaElement>("opp-memo").value = note.memo ?? "";

						lastClientResult = (note.client_result as unknown as CalcDamagesResult | null) ?? null;
						if (lastClientResult) {
							renderNoteResult(lastClientResult);
						}

						noteFormTitle.textContent = "対戦相手メモを編集";
						noteFormContainer.style.display = "block";
						noteFormContainer.scrollIntoView({ behavior: "smooth", block: "nearest" });
					}

					newNoteButton.addEventListener("click", openFormForNew);
					cancelNoteButton.addEventListener("click", () => {
						noteFormContainer.style.display = "none";
					});

					// --- 保存(新規作成 / 更新) ---
					saveNoteButton.addEventListener("click", () => {
						void (async () => {
							const name = el<HTMLInputElement>("opp-name").value.trim();
							if (!name) {
								noteFormStatusEl.textContent = "相手ポケモン名を入力してください。";
								return;
							}
							saveNoteButton.disabled = true;
							noteFormStatusEl.textContent = "保存中...";
							try {
								const opponentBuild = buildOpponentBuild();
								const field = buildOpponentField();
								const moveName = el<HTMLInputElement>("opp-move-name").value.trim();
								const memo = el<HTMLTextAreaElement>("opp-memo").value.trim();
								const editingId = noteForm.dataset.editingId ?? "";

								const payload: Record<string, unknown> = {
									opponent_build: opponentBuild,
									field,
									move_name: moveName === "" ? null : moveName,
									client_result: lastClientResult,
									memo: memo === "" ? null : memo,
								};

								let res: Response;
								if (editingId) {
									res = await fetch(`/api/opponent-notes/${encodeURIComponent(editingId)}`, {
										method: "PUT",
										credentials: "same-origin",
										headers: { "Content-Type": "application/json" },
										body: JSON.stringify(payload),
									});
								} else {
									payload.owned_pokemon_id = ownedPokemonId;
									res = await fetch("/api/opponent-notes", {
										method: "POST",
										credentials: "same-origin",
										headers: { "Content-Type": "application/json" },
										body: JSON.stringify(payload),
									});
								}

								if (!res.ok) {
									const errBody = (await res.json().catch(() => ({}))) as { error?: string };
									throw new Error(errBody.error ?? `保存に失敗しました (status=${res.status})`);
								}

								noteFormContainer.style.display = "none";
								await fetchNotes();
							} catch (err) {
								console.error(err);
								noteFormStatusEl.textContent = "保存に失敗しました。時間をおいて再度お試しください。";
							} finally {
								saveNoteButton.disabled = false;
							}
						})();
					});

					// --- 削除 ---
					async function deleteNote(id: string): Promise<void> {
						if (!window.confirm("この対戦相手メモを削除します。よろしいですか?")) return;
						try {
							const res = await fetch(`/api/opponent-notes/${encodeURIComponent(id)}`, {
								method: "DELETE",
								credentials: "same-origin",
							});
							if (!res.ok) throw new Error(`削除に失敗しました (status=${res.status})`);
							await fetchNotes();
						} catch (err) {
							console.error(err);
							window.alert("削除に失敗しました。時間をおいて再度お試しください。");
						}
					}

					// --- 一覧の取得・描画 ---
					function formatUpdatedAt(iso: string): string {
						try {
							return new Date(iso).toLocaleString("ja-JP");
						} catch {
							return iso;
						}
					}

					function renderNotesList(notes: OpponentNoteRecord[]): void {
						notesListEl.innerHTML = "";
						if (notes.length === 0) {
							const p = document.createElement("p");
							p.className = "opponent-note-empty";
							p.textContent = "まだ対戦相手メモがありません。";
							notesListEl.appendChild(p);
							return;
						}
						const ul = document.createElement("ul");
						ul.className = "opponent-note-list";
						for (const note of notes) {
							const build = note.opponent_build as unknown as OpponentBuildInput;
							const li = document.createElement("li");
							li.className = "opponent-note-item";

							const title = document.createElement("strong");
							title.textContent = build?.name || "(相手名未設定)";
							li.appendChild(title);

							if (note.move_name) {
								const move = document.createElement("span");
								move.className = "opponent-note-move";
								move.textContent = ` / 使用技: ${note.move_name}`;
								li.appendChild(move);
							}

							const meta = document.createElement("div");
							meta.className = "opponent-note-meta";
							meta.textContent = `最終更新: ${formatUpdatedAt(note.updated_at)}`;
							li.appendChild(meta);

							if (note.memo) {
								const memoP = document.createElement("p");
								memoP.className = "opponent-note-memo-preview";
								memoP.textContent = note.memo.length > 60 ? `${note.memo.slice(0, 60)}...` : note.memo;
								li.appendChild(memoP);
							}

							const actions = document.createElement("div");
							actions.className = "opponent-note-actions";
							const editBtn = document.createElement("button");
							editBtn.type = "button";
							editBtn.textContent = "編集";
							editBtn.addEventListener("click", () => openFormForEdit(note));
							const delBtn = document.createElement("button");
							delBtn.type = "button";
							delBtn.textContent = "削除";
							delBtn.addEventListener("click", () => void deleteNote(note.id));
							actions.appendChild(editBtn);
							actions.appendChild(delBtn);
							li.appendChild(actions);

							ul.appendChild(li);
						}
						notesListEl.appendChild(ul);
					}

					async function fetchNotes(): Promise<void> {
						notesListEl.innerHTML = "";
						const loadingP = document.createElement("p");
						loadingP.textContent = "読み込み中...";
						notesListEl.appendChild(loadingP);
						try {
							const res = await fetch(`/api/opponent-notes?owned_pokemon_id=${encodeURIComponent(ownedPokemonId)}`, {
								credentials: "same-origin",
							});
							if (!res.ok) throw new Error(`一覧の取得に失敗しました (status=${res.status})`);
							const body = (await res.json()) as { data: OpponentNoteRecord[] };
							renderNotesList(body.data);
						} catch (err) {
							console.error(err);
							notesListEl.innerHTML = "";
							const errP = document.createElement("p");
							errP.className = "opponent-note-empty";
							errP.textContent = "対戦相手メモの取得に失敗しました。時間をおいて再度お試しください。";
							notesListEl.appendChild(errP);
						}
					}

					renderEngineProgress({ status: "idle", message: "未初期化(ボタンを押すまでPyodideはロードされません)" });
					void fetchNotes();
				}

				void loadAutocomplete();
			}
		</script>
	</body>
</html>
