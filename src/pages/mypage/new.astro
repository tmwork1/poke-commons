---
// Phase C-3: 個体の新規登録フォーム (育成データ管理計画.md §6.2, §8 Phase C-3)。
// src/pages/builds/new.astro を強く参考にする(NATURES/TERA_TYPES定数、努力値・個体値の
// 入力欄、フォームのCSS)が、Pyodideの計算エンジンはこのページでは使わない(実数値計算は
// 既存builds/damage-calcで代替可能、個体管理は保存・編集が主目的)。
// 新規作成は明示的な保存操作(builds/new.astroと同様)。保存に成功したら編集ページ
// (/mypage/[id])へ遷移し、以後はそちらで自動保存編集を続けられるようにする。
// 未ログイン時はログインを促すのみで強制リダイレクトしない(Phase A-3の方針を踏襲)。
export const prerender = false;

const user = Astro.locals.user;

const NATURES = [
	"まじめ", "さみしがり", "いじっぱり", "やんちゃ", "ゆうかん",
	"ずぶとい", "わんぱく", "のうてんき", "のんき",
	"ひかえめ", "おっとり", "うっかりや", "れいせい",
	"おだやか", "おとなしい", "しんちょう", "なまいき",
	"おくびょう", "せっかち", "ようき", "むじゃき",
	"てれや", "がんばりや", "すなお", "きまぐれ",
];

const TERA_TYPES = [
	"ノーマル", "ほのお", "みず", "でんき", "くさ", "こおり", "かくとう", "どく", "じめん",
	"ひこう", "エスパー", "むし", "いわ", "ゴースト", "ドラゴン", "あく", "はがね", "フェアリー", "ステラ",
];

const STAT_LABELS: Array<{ key: string; label: string }> = [
	{ key: "hp", label: "HP" },
	{ key: "atk", label: "攻撃" },
	{ key: "def", label: "防御" },
	{ key: "spa", label: "特攻" },
	{ key: "spd", label: "特防" },
	{ key: "spe", label: "素早さ" },
];

const MOVE_SLOTS = [1, 2, 3, 4];
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>個体を登録 | Poke-Commons</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 960px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			section {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 1rem;
				margin: 1rem 0;
			}
			fieldset {
				border: 1px solid #ddd;
				border-radius: 6px;
				padding: 0.8rem;
				margin: 0;
			}
			label { display: inline-block; min-width: 6em; }
			.row { margin: 0.5rem 0; }
			input[type="text"], input[type="number"], input[type="search"], select, textarea {
				padding: 0.3em 0.5em;
				font: inherit;
			}
			input[type="text"] { min-width: 12em; }
			textarea { width: 100%; min-height: 4em; }
			.stat-grid-label { display: block; font-size: 0.9em; color: #555; margin-bottom: 0.2rem; }
			.stat-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.stat-input {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				font-size: 0.85em;
				min-width: 0;
			}
			.stat-input input { width: 4.5em; }
			.move-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.move-input-group { display: flex; flex-direction: column; gap: 0.2em; }
			.move-input-group a { font-size: 0.8em; }
			button, .login-button {
				padding: 0.5em 1.2em;
				font-size: 1rem;
				cursor: pointer;
			}
			button:disabled { cursor: not-allowed; opacity: 0.6; }
			#save-status { font-weight: bold; }
			#save-status[data-state="error"] { color: #c62828; }
			#save-status[data-state="success"] { color: #2e7d32; }
			.pokemon-name-row { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
			#pokemon-detail-link { font-size: 0.9em; }
		</style>
	</head>
	<body>
		<h1>個体を登録</h1>
		<p><a href="/mypage">マイページへ戻る</a></p>

		{
			user ? (
				<form id="create-form">
					<section>
						<h2>基本情報</h2>
						<div class="row">
							<label for="nickname">ニックネーム</label>
							<input id="nickname" type="text" autocomplete="off" />
						</div>
						<div class="row pokemon-name-row">
							<label for="species-name">ポケモン名</label>
							<input id="species-name" type="text" list="pokemon-list" autocomplete="off" required />
							<a id="pokemon-detail-link" href="#" target="_blank" rel="noopener" hidden>図鑑で見る</a>
						</div>
						<div class="row">
							<label for="level">レベル</label>
							<input id="level" type="number" min="1" max="100" step="1" placeholder="未設定" />
						</div>
						<div class="row">
							<label for="nature">性格</label>
							<select id="nature">
								<option value="">未設定</option>
								{NATURES.map((n) => <option value={n}>{n}</option>)}
							</select>
						</div>
						<div class="row">
							<label for="ability">特性</label>
							<input id="ability" type="text" list="ability-list" autocomplete="off" />
						</div>
						<div class="row">
							<label for="item">持ち物</label>
							<input id="item" type="text" list="item-list" autocomplete="off" />
						</div>
						<div class="row">
							<label for="tera">テラスタイプ</label>
							<select id="tera">
								<option value="">なし</option>
								{TERA_TYPES.map((t) => <option value={t}>{t}</option>)}
							</select>
						</div>
					</section>

					<section>
						<h2>努力値・個体値</h2>
						<fieldset>
							<div class="row stat-grid">
								<span class="stat-grid-label">努力値(0〜32)</span>
								<div class="stat-inputs">
									{STAT_LABELS.map(({ key, label: statLabel }) => (
										<label class="stat-input">
											{statLabel}
											<input id={`ev-${key}`} type="number" min="0" max="32" step="1" value="0" />
										</label>
									))}
								</div>
							</div>
							<div class="row stat-grid" style="margin-top: 0.8rem;">
								<span class="stat-grid-label">個体値(省略可・既定31)</span>
								<div class="stat-inputs">
									{STAT_LABELS.map(({ key, label: statLabel }) => (
										<label class="stat-input">
											{statLabel}
											<input id={`iv-${key}`} type="number" min="0" max="31" step="1" placeholder="31" />
										</label>
									))}
								</div>
							</div>
						</fieldset>
					</section>

					<section>
						<h2>技構成(最大4つ・任意)</h2>
						<div class="move-inputs">
							{MOVE_SLOTS.map((slot) => (
								<div class="move-input-group">
									<input id={`move-${slot}`} type="text" list="move-list" autocomplete="off" placeholder={`技${slot}`} />
								</div>
							))}
						</div>
					</section>

					<section>
						<h2>タグ・メモ</h2>
						<div class="row">
							<label for="tags">タグ</label>
							<input id="tags" type="text" placeholder="カンマ区切り(例: エース, 対面)" autocomplete="off" />
						</div>
						<div class="row">
							<label><input id="is-pinned" type="checkbox" /> ピン留めする</label>
						</div>
						<div class="row">
							<label for="memo">メモ</label><br />
							<textarea id="memo" rows="4"></textarea>
						</div>
					</section>

					<section>
						<button id="save-button" type="button">登録する</button>
						<p id="save-status">(未保存)</p>
					</section>
				</form>
			) : (
				<section>
					<p>個体を登録するにはログインが必要です。</p>
					<a class="login-button" href="/api/auth/login">Googleでログイン</a>
				</section>
			)
		}

		<datalist id="pokemon-list"></datalist>
		<datalist id="move-list"></datalist>
		<datalist id="ability-list"></datalist>
		<datalist id="item-list"></datalist>

		<script>
			import {
				el,
				loadAutocomplete,
				readEv,
				readIv,
				readMoveNames,
				parseTagsInput,
				pokemonDetailHref,
			} from "../../lib/owned-pokemon-form";

			const form = document.getElementById("create-form");
			if (form) {
				const STAT_KEYS = ["hp", "atk", "def", "spa", "spd", "spe"] as const;
				const speciesInput = el<HTMLInputElement>("species-name");
				const detailLink = el<HTMLAnchorElement>("pokemon-detail-link");
				const saveButton = el<HTMLButtonElement>("save-button");
				const saveStatusEl = el<HTMLElement>("save-status");

				function updateDetailLink(): void {
					const name = speciesInput.value.trim();
					if (name === "") {
						detailLink.hidden = true;
						return;
					}
					detailLink.href = pokemonDetailHref(name);
					detailLink.hidden = false;
				}
				speciesInput.addEventListener("input", updateDetailLink);

				interface SaveResponseBody {
					data?: { id: string };
					error?: string;
				}

				function readLevel(): number | null {
					const raw = el<HTMLInputElement>("level").value.trim();
					if (raw === "") return null;
					const n = Number(raw);
					if (!Number.isFinite(n)) return null;
					return Math.min(100, Math.max(1, Math.round(n)));
				}

				async function save(): Promise<void> {
					const speciesName = speciesInput.value.trim();
					if (!speciesName) {
						saveStatusEl.dataset.state = "error";
						saveStatusEl.textContent = "ポケモン名を入力してください";
						return;
					}

					const payload = {
						nickname: el<HTMLInputElement>("nickname").value.trim(),
						species_name: speciesName,
						level: readLevel(),
						nature: el<HTMLSelectElement>("nature").value,
						ability_name: el<HTMLInputElement>("ability").value.trim(),
						item_name: el<HTMLInputElement>("item").value.trim(),
						tera_type: el<HTMLSelectElement>("tera").value,
						evs: STAT_KEYS.map((k) => readEv(k)),
						ivs: STAT_KEYS.map((k) => readIv(k)),
						move_names: readMoveNames(),
						memo: el<HTMLTextAreaElement>("memo").value.trim(),
						tags: parseTagsInput(el<HTMLInputElement>("tags").value),
						is_pinned: el<HTMLInputElement>("is-pinned").checked,
					};

					saveButton.disabled = true;
					saveStatusEl.dataset.state = "";
					saveStatusEl.textContent = "登録中...";

					try {
						const res = await fetch("/api/owned-pokemon", {
							method: "POST",
							credentials: "same-origin",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify(payload),
						});
						const body = (await res.json().catch(() => ({}))) as SaveResponseBody;
						if (!res.ok || !body.data) {
							throw new Error(body.error ?? `登録に失敗しました (status=${res.status})`);
						}
						saveStatusEl.dataset.state = "success";
						saveStatusEl.textContent = "登録しました。編集ページへ移動します...";
						window.location.href = `/mypage/${encodeURIComponent(body.data.id)}`;
					} catch (err) {
						console.error(err);
						saveStatusEl.dataset.state = "error";
						saveStatusEl.textContent = "エラー: " + (err instanceof Error ? err.message : String(err));
						saveButton.disabled = false;
					}
				}

				saveButton.addEventListener("click", () => {
					void save();
				});

				void loadAutocomplete();
			}
		</script>
	</body>
</html>
