---
// Phase C-2: 個体一覧ページ (育成データ管理計画.md §6.1, §8 Phase C-2)。
// ログイン時は GET /api/owned-pokemon から取得した一覧をクライアント側で描画する
// (並び替え・タグフィルタ・文字列検索はいずれも初回取得後にクライアント側で完結させ、
// 操作のたびに追加のAPI呼び出しを発生させない設計。計画書§6.1が文字列検索のクライアント側
// フィルタを明示的に許容しているため、他の絞り込みも同じ方針に揃えている)。
// 未ログイン時の表示は Phase A-3 から変更しない(強制リダイレクトはしない)。
export const prerender = false;

const user = Astro.locals.user;
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>マイページ | Poke-Commons</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 960px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			.login-button, .logout-button, .primary-button {
				display: inline-block;
				padding: 0.6em 1.2em;
				border-radius: 6px;
				border: 1px solid #ccc;
				background: #fff;
				font-size: 1rem;
				cursor: pointer;
			}
			.login-button, .primary-button { text-decoration: none; color: inherit; }
			.primary-button { background: #2e7d32; color: #fff; border-color: #2e7d32; }

			.toolbar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				align-items: center;
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 0.8rem 1rem;
				margin: 1rem 0;
			}
			.toolbar label { font-size: 0.9em; }
			.toolbar select, .toolbar input[type="search"] { padding: 0.3em 0.5em; }
			.tag-filter-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
			.tag-chip {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				border: 1px solid #ccc;
				border-radius: 999px;
				padding: 0.1em 0.7em;
				font-size: 0.85em;
				cursor: pointer;
				user-select: none;
			}
			.tag-chip.active { background: #2e7d32; color: #fff; border-color: #2e7d32; }

			#owned-pokemon-list {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
				gap: 0.8rem;
			}
			.pokemon-card {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 0.8rem 1rem;
				position: relative;
			}
			.pokemon-card.is-pinned { border-color: #b8860b; background: #fffdf5; }
			.pokemon-card h3 { margin: 0 0 0.3rem; font-size: 1.05em; }
			.pokemon-card .species { color: #555; font-size: 0.9em; }
			.pokemon-card .meta { font-size: 0.85em; color: #555; margin: 0.4rem 0; }
			.pokemon-card .tags { display: flex; flex-wrap: wrap; gap: 0.3em; margin: 0.4rem 0; }
			.pokemon-card .tags span {
				border: 1px solid #ddd;
				border-radius: 999px;
				padding: 0.05em 0.6em;
				font-size: 0.8em;
			}
			.pokemon-card .card-actions { display: flex; gap: 0.5rem; margin-top: 0.6rem; }
			.pokemon-card .card-actions a, .pokemon-card .card-actions button {
				font-size: 0.85em;
				padding: 0.3em 0.7em;
				border-radius: 6px;
				border: 1px solid #ccc;
				background: #fff;
				cursor: pointer;
				text-decoration: none;
				color: inherit;
			}
			.pin-toggle[data-pinned="true"] { background: #b8860b; color: #fff; border-color: #b8860b; }
			.delete-button { color: #c62828; }
			#empty-message, #error-message, #loading-message { color: #555; }
			#error-message { color: #c62828; }
		</style>
	</head>
	<body>
		<h1>マイページ</h1>
		<p><a href="/">トップへ戻る</a></p>
		{
			user ? (
				<Fragment>
					<section>
						<p>ログイン中: {user.email ?? user.displayName ?? user.id}</p>
						<form method="POST" action="/api/auth/logout">
							<button type="submit" class="logout-button">ログアウト</button>
						</form>
					</section>

					<section>
						<h2>手持ちポケモン</h2>
						<p>
							<a class="primary-button" href="/mypage/new">＋ 新規登録</a>
						</p>

						<div class="toolbar">
							<label for="sort-select">並び替え</label>
							<select id="sort-select">
								<option value="updated_at">最終更新順</option>
								<option value="last_used_at">最終使用順</option>
								<option value="nickname">ニックネーム順</option>
							</select>

							<label for="search-input">検索</label>
							<input
								id="search-input"
								type="search"
								placeholder="ニックネーム・種族・特性・持ち物・テラス・技"
								autocomplete="off"
							/>
						</div>
						<div class="toolbar" id="tag-filter-toolbar" hidden>
							<span>タグで絞り込み(すべて一致):</span>
							<div class="tag-filter-list" id="tag-filter-list"></div>
						</div>

						<p id="loading-message">読み込み中...</p>
						<p id="error-message" hidden></p>
						<p id="empty-message" hidden>登録された個体がありません。「新規登録」から追加してください。</p>
						<div id="owned-pokemon-list"></div>
					</section>
				</Fragment>
			) : (
				<section>
					<p>個体管理機能を利用するにはログインが必要です。</p>
					<a class="login-button" href="/api/auth/login">Googleでログイン</a>
				</section>
			)
		}

		<script>
			interface OwnedPokemon {
				id: string;
				nickname: string | null;
				species_name: string;
				level: number | null;
				nature: string | null;
				ability_name: string | null;
				item_name: string | null;
				tera_type: string | null;
				evs: number[];
				ivs: number[];
				move_names: string[];
				memo: string | null;
				tags: string[];
				is_pinned: boolean;
				updated_at: string;
				last_used_at: string | null;
			}

			function el<T extends HTMLElement>(id: string): T {
				const found = document.getElementById(id);
				if (!found) throw new Error(`要素が見つかりません: #${id}`);
				return found as T;
			}

			const listRoot = document.getElementById("owned-pokemon-list");
			if (listRoot) {
				const loadingMessage = el<HTMLElement>("loading-message");
				const errorMessage = el<HTMLElement>("error-message");
				const emptyMessage = el<HTMLElement>("empty-message");
				const sortSelect = el<HTMLSelectElement>("sort-select");
				const searchInput = el<HTMLInputElement>("search-input");
				const tagFilterToolbar = el<HTMLElement>("tag-filter-toolbar");
				const tagFilterList = el<HTMLElement>("tag-filter-list");

				let allPokemon: OwnedPokemon[] = [];
				const activeTags = new Set<string>();

				function displayName(p: OwnedPokemon): string {
					return p.nickname && p.nickname.trim() !== "" ? p.nickname : p.species_name;
				}

				function formatDateTime(iso: string | null): string {
					if (!iso) return "-";
					const d = new Date(iso);
					if (Number.isNaN(d.getTime())) return "-";
					return d.toLocaleString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" });
				}

				function renderTagFilters(): void {
					const tagSet = new Set<string>();
					for (const p of allPokemon) {
						for (const t of p.tags) tagSet.add(t);
					}
					const tags = Array.from(tagSet).sort((a, b) => a.localeCompare(b, "ja"));
					tagFilterToolbar.hidden = tags.length === 0;
					tagFilterList.innerHTML = "";
					for (const tag of tags) {
						const chip = document.createElement("button");
						chip.type = "button";
						chip.className = "tag-chip" + (activeTags.has(tag) ? " active" : "");
						chip.textContent = tag;
						chip.addEventListener("click", () => {
							if (activeTags.has(tag)) activeTags.delete(tag);
							else activeTags.add(tag);
							renderTagFilters();
							renderList();
						});
						tagFilterList.appendChild(chip);
					}
				}

				function matchesSearch(p: OwnedPokemon, term: string): boolean {
					if (!term) return true;
					const haystack = [
						p.nickname ?? "",
						p.species_name,
						p.ability_name ?? "",
						p.item_name ?? "",
						p.tera_type ?? "",
						...p.move_names,
					]
						.join(" ")
						.toLowerCase();
					// AND部分一致(空白区切りの複数語すべてを含む場合のみ一致、計画書§6.1)
					return term
						.toLowerCase()
						.split(/\s+/)
						.filter((t) => t.length > 0)
						.every((token) => haystack.includes(token));
				}

				function matchesTags(p: OwnedPokemon): boolean {
					if (activeTags.size === 0) return true;
					return Array.from(activeTags).every((t) => p.tags.includes(t));
				}

				function sortPokemon(list: OwnedPokemon[]): OwnedPokemon[] {
					const sort = sortSelect.value;
					const sorted = [...list].sort((a, b) => {
						if (sort === "last_used_at") {
							const av = a.last_used_at ? new Date(a.last_used_at).getTime() : -Infinity;
							const bv = b.last_used_at ? new Date(b.last_used_at).getTime() : -Infinity;
							return bv - av;
						}
						if (sort === "nickname") {
							return displayName(a).localeCompare(displayName(b), "ja");
						}
						return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime();
					});
					// ピン留めは常に上部固定(計画書§6.1)
					sorted.sort((a, b) => Number(b.is_pinned) - Number(a.is_pinned));
					return sorted;
				}

				function renderCard(p: OwnedPokemon): HTMLElement {
					const card = document.createElement("div");
					card.className = "pokemon-card" + (p.is_pinned ? " is-pinned" : "");

					const title = document.createElement("h3");
					title.textContent = displayName(p);
					card.appendChild(title);

					const species = document.createElement("div");
					species.className = "species";
					species.textContent = p.species_name + (p.level ? ` Lv.${p.level}` : "");
					card.appendChild(species);

					const meta = document.createElement("div");
					meta.className = "meta";
					const metaParts = [p.nature, p.ability_name, p.item_name, p.tera_type ? `テラス:${p.tera_type}` : null].filter(
						(v): v is string => !!v,
					);
					meta.textContent = metaParts.length > 0 ? metaParts.join(" / ") : "(未設定)";
					card.appendChild(meta);

					if (p.move_names.length > 0) {
						const moves = document.createElement("div");
						moves.className = "meta";
						moves.textContent = "技: " + p.move_names.join(" / ");
						card.appendChild(moves);
					}

					if (p.tags.length > 0) {
						const tagsEl = document.createElement("div");
						tagsEl.className = "tags";
						for (const t of p.tags) {
							const span = document.createElement("span");
							span.textContent = t;
							tagsEl.appendChild(span);
						}
						card.appendChild(tagsEl);
					}

					const updated = document.createElement("div");
					updated.className = "meta";
					updated.textContent = `最終更新: ${formatDateTime(p.updated_at)}`;
					card.appendChild(updated);

					const actions = document.createElement("div");
					actions.className = "card-actions";

					const editLink = document.createElement("a");
					editLink.href = `/mypage/${encodeURIComponent(p.id)}`;
					editLink.textContent = "編集";
					actions.appendChild(editLink);

					const pinButton = document.createElement("button");
					pinButton.type = "button";
					pinButton.className = "pin-toggle";
					pinButton.dataset.pinned = String(p.is_pinned);
					pinButton.textContent = p.is_pinned ? "★ ピン留め中" : "☆ ピン留め";
					pinButton.addEventListener("click", () => void togglePin(p));
					actions.appendChild(pinButton);

					const deleteButton = document.createElement("button");
					deleteButton.type = "button";
					deleteButton.className = "delete-button";
					deleteButton.textContent = "削除";
					deleteButton.addEventListener("click", () => void deletePokemon(p));
					actions.appendChild(deleteButton);

					card.appendChild(actions);
					return card;
				}

				function renderList(): void {
					const filtered = allPokemon.filter((p) => matchesTags(p) && matchesSearch(p, searchInput.value.trim()));
					const sorted = sortPokemon(filtered);
					listRoot.innerHTML = "";
					emptyMessage.hidden = sorted.length !== 0 || allPokemon.length === 0;
					if (sorted.length === 0 && allPokemon.length > 0) {
						const noMatch = document.createElement("p");
						noMatch.textContent = "条件に一致する個体がありません。";
						listRoot.appendChild(noMatch);
						return;
					}
					for (const p of sorted) {
						listRoot.appendChild(renderCard(p));
					}
				}

				async function togglePin(p: OwnedPokemon): Promise<void> {
					try {
						const res = await fetch(`/api/owned-pokemon/${encodeURIComponent(p.id)}`, {
							method: "PUT",
							credentials: "same-origin",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({
								nickname: p.nickname,
								species_name: p.species_name,
								level: p.level,
								nature: p.nature,
								ability_name: p.ability_name,
								item_name: p.item_name,
								tera_type: p.tera_type,
								// PUTは全項目上書きの設計(§6.2)のため、evs/ivs/memoを送り忘れると
								// デフォルト値([0,0,0,0,0,0] / [31,...,31] / null)で消えてしまう。
								// ピン留めのトグルだけのつもりでも、一覧が保持している最新値をそのまま送り返す。
								evs: p.evs,
								ivs: p.ivs,
								move_names: p.move_names,
								memo: p.memo,
								tags: p.tags,
								is_pinned: !p.is_pinned,
							}),
						});
						if (!res.ok) throw new Error(`ピン留めの更新に失敗しました (status=${res.status})`);
						const body = (await res.json()) as { data: OwnedPokemon };
						const idx = allPokemon.findIndex((x) => x.id === p.id);
						if (idx !== -1) allPokemon[idx] = body.data;
						renderList();
					} catch (err) {
						console.error(err);
						window.alert("ピン留めの更新に失敗しました。時間をおいて再度お試しください。");
					}
				}

				async function deletePokemon(p: OwnedPokemon): Promise<void> {
					if (!window.confirm(`「${displayName(p)}」を削除します。よろしいですか?`)) return;
					try {
						const res = await fetch(`/api/owned-pokemon/${encodeURIComponent(p.id)}`, {
							method: "DELETE",
							credentials: "same-origin",
						});
						if (!res.ok) throw new Error(`削除に失敗しました (status=${res.status})`);
						allPokemon = allPokemon.filter((x) => x.id !== p.id);
						renderTagFilters();
						renderList();
					} catch (err) {
						console.error(err);
						window.alert("削除に失敗しました。時間をおいて再度お試しください。");
					}
				}

				async function loadList(): Promise<void> {
					loadingMessage.hidden = false;
					errorMessage.hidden = true;
					try {
						const res = await fetch("/api/owned-pokemon", { credentials: "same-origin" });
						if (!res.ok) throw new Error(`一覧の取得に失敗しました (status=${res.status})`);
						const body = (await res.json()) as { data: OwnedPokemon[] };
						allPokemon = body.data;
						loadingMessage.hidden = true;
						renderTagFilters();
						renderList();
					} catch (err) {
						console.error(err);
						loadingMessage.hidden = true;
						errorMessage.hidden = false;
						errorMessage.textContent = "一覧の取得に失敗しました。時間をおいて再度お試しください。";
					}
				}

				sortSelect.addEventListener("change", renderList);
				searchInput.addEventListener("input", renderList);

				void loadList();
			}
		</script>
	</body>
</html>
