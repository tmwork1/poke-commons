---
// Phase 3-1: 育成の公開閲覧ページ (/builds/[slug])。
// POST /api/builds が発行した share_slug から育成内容を表示する。
// SSRページなので GET /api/builds/:slug 相当のデータ取得はここで getSupabasePublicClient() を
// 直接使う (内部fetch往復を避ける、api/builds/[slug].ts と同じ最小権限方針)。
import { getSupabasePublicClient } from '../../lib/supabase';

// API ルート (src/pages/api/**) と同じく、動的ルートはSSRで都度サーバレンダリングする
// (ビルド時の静的プリレンダリングではなく、リクエストのたびにDBを参照するため)。
export const prerender = false;

const { slug } = Astro.params;

const STAT_LABELS: Array<{ key: 'hp' | 'atk' | 'def' | 'spa' | 'spd' | 'spe'; label: string }> = [
	{ key: 'hp', label: 'HP' },
	{ key: 'atk', label: '攻撃' },
	{ key: 'def', label: '防御' },
	{ key: 'spa', label: '特攻' },
	{ key: 'spd', label: '特防' },
	{ key: 'spe', label: '素早さ' },
];

interface BuildRow {
	id: string;
	pokemon_name: string;
	nature: string | null;
	ability_name: string | null;
	item_name: string | null;
	tera_type: string | null;
	evs: number[];
	ivs: number[];
	move_names: string[];
	share_slug: string;
	created_at: string;
}

let build: BuildRow | null = null;

if (slug) {
	const supabase = await getSupabasePublicClient();
	// RLS の builds_public_read ポリシー (is_public = true のみ) を経由するため、
	// 非公開ビルドはここで自然に0件になる (api/builds/[slug].ts と同じ)。
	const { data, error } = await supabase
		.from('builds')
		.select('id, pokemon_name, nature, ability_name, item_name, tera_type, evs, ivs, move_names, share_slug, created_at')
		.eq('share_slug', slug)
		.maybeSingle();

	if (error) {
		// eslint-disable-next-line no-console
		console.error('Failed to fetch build:', error);
	} else {
		build = data as BuildRow | null;
	}
}

if (!build) {
	Astro.response.status = 404;
}

// pokemon_name 等は自由入力文字列(実在ポケモン名限定のバリデーションはしていない)なので、
// <script>タグへ埋め込む際に "</script>" 等でタグを閉じて注入されないよう "</" をエスケープする
// (JSONをscriptタグに安全に埋め込む定石)。
function safeJsonForScript(value: unknown): string {
	return JSON.stringify(value).replace(/</g, '\\u003c');
}
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{build ? `${build.pokemon_name}の育成 | Poke-Commons` : '見つかりません | Poke-Commons'}</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 720px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			section {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 1rem;
				margin: 1rem 0;
			}
			dl { display: grid; grid-template-columns: 8em 1fr; gap: 0.4rem 1rem; margin: 0; }
			dt { font-weight: bold; color: #555; }
			dd { margin: 0; }
			table { border-collapse: collapse; width: 100%; }
			th, td { border: 1px solid #ddd; padding: 0.4em 0.6em; text-align: right; }
			th:first-child, td:first-child { text-align: left; }
			button {
				padding: 0.5em 1.2em;
				font-size: 1rem;
				cursor: pointer;
			}
			button:disabled { cursor: not-allowed; opacity: 0.6; }
			#engine-status { font-weight: bold; }
			#engine-status[data-state="loading"] { color: #b8860b; }
			#engine-status[data-state="ready"] { color: #2e7d32; }
			#engine-status[data-state="error"] { color: #c62828; }
			.spinner {
				display: inline-block; width: 1em; height: 1em; border: 2px solid #ccc;
				border-top-color: #b8860b; border-radius: 50%; animation: spin 0.8s linear infinite;
				margin-right: 0.5em; vertical-align: -0.15em;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.cta { margin-top: 1rem; }
		</style>
	</head>
	<body>
		<p><a href="/">トップへ戻る</a></p>

		{!build ? (
			<>
				<h1>見つかりません</h1>
				<p>指定された育成は存在しないか、非公開に設定されています。</p>
			</>
		) : (
			<>
				<h1>{build.pokemon_name}の育成</h1>

				<section>
					<h2>育成内容</h2>
					<dl>
						<dt>ポケモン</dt>
						<dd>{build.pokemon_name}</dd>
						<dt>性格</dt>
						<dd>{build.nature ?? '(未設定)'}</dd>
						<dt>特性</dt>
						<dd>{build.ability_name ?? '(未設定)'}</dd>
						<dt>持ち物</dt>
						<dd>{build.item_name ?? '(未設定)'}</dd>
						<dt>テラスタイプ</dt>
						<dd>{build.tera_type ?? '(未設定)'}</dd>
						<dt>技構成</dt>
						<dd>{build.move_names.length > 0 ? build.move_names.join(' / ') : '(未設定)'}</dd>
					</dl>
				</section>

				<section>
					<h2>努力値・個体値</h2>
					<table>
						<thead>
							<tr>
								<th>ステータス</th>
								{STAT_LABELS.map(({ label }) => <th>{label}</th>)}
							</tr>
						</thead>
						<tbody>
							<tr>
								<td>努力値</td>
								{STAT_LABELS.map((_, i) => <td>{build!.evs[i] ?? 0}</td>)}
							</tr>
							<tr>
								<td>個体値</td>
								{STAT_LABELS.map((_, i) => <td>{build!.ivs[i] ?? 31}</td>)}
							</tr>
						</tbody>
					</table>
				</section>

				<section>
					<h2>実数値</h2>
					<p>
						<button id="calc-stats-button" type="button">実数値を計算する</button>
					</p>
					<p id="engine-status" data-state="idle">未計算(ボタンを押すまでPyodideはロードされません)</p>
					<table id="stats-table" hidden>
						<thead>
							<tr>
								{STAT_LABELS.map(({ label }) => <th>{label}</th>)}
							</tr>
						</thead>
						<tbody>
							<tr id="stats-row">
								{STAT_LABELS.map(() => <td>-</td>)}
							</tr>
						</tbody>
					</table>
				</section>

				<p class="cta">
					<a href={`/damage-calc?build=${build.share_slug}`}>
						<button type="button">この育成でダメージ計算する</button>
					</a>
				</p>

				{/* サーバ側で取得した育成データをブラウザ専用<script>へ橋渡しするためのJSON。
					Astroのdefine:varsはスクリプトを非処理(inline)化しVite経由の静的importが
					使えなくなるため、damage-calcページと同じ「static importするmoduleスクリプト」
					のパターンを保つ目的でこの方式を採る。 */}
				<script type="application/json" id="build-data" set:html={safeJsonForScript(build)} />

				<script>
					import { initEngine, calcStats, registerOfflineCache, type PokemonSpec } from "../../lib/pyodide-engine";

					interface BuildData {
						pokemon_name: string;
						nature: string | null;
						ability_name: string | null;
						item_name: string | null;
						tera_type: string | null;
						evs: number[];
						ivs: number[];
						move_names: string[];
					}

					function el<T extends HTMLElement>(id: string): T {
						const found = document.getElementById(id);
						if (!found) {
							throw new Error(`要素が見つかりません: #${id}`);
						}
						return found as T;
					}

					const STAT_KEYS = ["hp", "atk", "def", "spa", "spd", "spe"] as const;

					const buildDataEl = el<HTMLScriptElement>("build-data");
					const build = JSON.parse(buildDataEl.textContent ?? "null") as BuildData | null;

					const statusEl = el<HTMLElement>("engine-status");
					const calcButton = el<HTMLButtonElement>("calc-stats-button");
					const statsTable = el<HTMLTableElement>("stats-table");
					const statsRow = el<HTMLTableRowElement>("stats-row");

					function renderProgress(progress: { status: string; message: string }) {
						statusEl.dataset.state = progress.status;
						const spinner = progress.status === "loading" ? '<span class="spinner"></span>' : "";
						statusEl.innerHTML = spinner + progress.message;
					}

					calcButton.addEventListener("click", async () => {
						if (!build) return;
						calcButton.disabled = true;
						try {
							await initEngine(renderProgress);
							const spec: PokemonSpec = {
								name: build.pokemon_name,
								nature: build.nature ?? undefined,
								abilityName: build.ability_name ?? undefined,
								itemName: build.item_name ?? undefined,
								teraType: build.tera_type ?? undefined,
								moveNames: build.move_names,
								evs: build.evs,
								ivs: build.ivs,
							};
							const { stats } = await calcStats(spec);
							statsRow.innerHTML = "";
							for (const key of STAT_KEYS) {
								const td = document.createElement("td");
								td.textContent = String(stats[key]);
								statsRow.appendChild(td);
							}
							statsTable.hidden = false;
						} catch (err) {
							console.error(err);
							statusEl.dataset.state = "error";
							statusEl.textContent = "エラー: " + (err instanceof Error ? err.message : String(err));
						} finally {
							calcButton.disabled = false;
						}
					});

					renderProgress({ status: "idle", message: "未計算(ボタンを押すまでPyodideはロードされません)" });
					// Pyodide自体のロードは開始しない(SW登録のみ)。damage-calc ページと同じ方針。
					registerOfflineCache();
				</script>
			</>
		)}
	</body>
</html>
