---
// Phase 3-2: 育成ビルダー UI。
//
// 設計方針は damage-calc/index.astro (Phase 2-2 本番UI) を踏襲する:
//   - このページ自体は SSR のプレースホルダー(静的な選択肢リストの描画のみ)。
//   - Pyodide / jpoke まわりの処理はすべて下部の <script> (ブラウザ専用) に閉じ込める。
//   - Pyodide の初期化はページ読み込み時ではなく「計算エンジンを読み込む」ボタン操作まで遅延させる。
// src/lib/pyodide-engine.ts はここ以外から import しないこと
// (SSR環境には window/document が無く、読み込んだ瞬間に失敗する)。
//
// 保存先 `POST /api/builds` は別エージェントが並行実装中(契約のみ確定済み)。
// 遷移先 `/builds/[slug]` も別エージェントが並行実装中(パスの契約のみ確定済み)。

// 性格一覧 (vendor/jpoke/src/jpoke/data/nature.py の NATURE_MODIFIER キー一覧と同期させること。
// damage-calc/index.astro の NATURES と同じ内容に保つこと)
const NATURES = [
	"まじめ", "さみしがり", "いじっぱり", "やんちゃ", "ゆうかん",
	"ずぶとい", "わんぱく", "のうてんき", "のんき",
	"ひかえめ", "おっとり", "うっかりや", "れいせい",
	"おだやか", "おとなしい", "しんちょう", "なまいき",
	"おくびょう", "せっかち", "ようき", "むじゃき",
	"てれや", "がんばりや", "すなお", "きまぐれ",
];

// テラスタイプ一覧 (vendor/jpoke/src/jpoke/types/literals.py の Type リテラルと同期させること。
// damage-calc/index.astro の TERA_TYPES と同じ内容に保つこと。空文字列=なし は別途先頭に追加)
const TERA_TYPES = [
	"ノーマル", "ほのお", "みず", "でんき", "くさ", "こおり", "かくとう", "どく", "じめん",
	"ひこう", "エスパー", "むし", "いわ", "ゴースト", "ドラゴン", "あく", "はがね", "フェアリー", "ステラ",
];

const STAT_LABELS: Array<{ key: string; label: string }> = [
	{ key: "hp", label: "HP" },
	{ key: "atk", label: "攻撃" },
	{ key: "def", label: "防御" },
	{ key: "spa", label: "特攻" },
	{ key: "spd", label: "特防" },
	{ key: "spe", label: "素早さ" },
];

const MOVE_SLOTS = [1, 2, 3, 4];
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>育成ビルダー | Poke-Commons</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				max-width: 960px;
				margin: 2rem auto;
				padding: 0 1rem;
				line-height: 1.6;
			}
			h1 { font-size: 1.5rem; }
			h2 { font-size: 1.15rem; }
			h3 { font-size: 1rem; margin-bottom: 0.3rem; }
			section {
				border: 1px solid #ccc;
				border-radius: 8px;
				padding: 1rem;
				margin: 1rem 0;
			}
			fieldset {
				border: 1px solid #ddd;
				border-radius: 6px;
				padding: 0.8rem;
				margin: 0;
			}
			label { display: inline-block; min-width: 6em; }
			.row { margin: 0.5rem 0; }
			input[type="text"], input[type="number"], select {
				padding: 0.3em 0.5em;
			}
			input[type="text"] { min-width: 12em; }
			.stat-grid-label { display: block; font-size: 0.9em; color: #555; margin-bottom: 0.2rem; }
			.stat-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			.stat-input {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				font-size: 0.85em;
				min-width: 0;
			}
			.stat-input input { width: 4.5em; }
			.move-inputs { display: flex; flex-wrap: wrap; gap: 0.6rem; }
			button {
				padding: 0.5em 1.2em;
				font-size: 1rem;
				cursor: pointer;
			}
			button:disabled { cursor: not-allowed; opacity: 0.6; }
			#engine-status { font-weight: bold; }
			#engine-status[data-state="loading"] { color: #b8860b; }
			#engine-status[data-state="ready"] { color: #2e7d32; }
			#engine-status[data-state="error"] { color: #c62828; }
			.spinner {
				display: inline-block; width: 1em; height: 1em; border: 2px solid #ccc;
				border-top-color: #b8860b; border-radius: 50%; animation: spin 0.8s linear infinite;
				margin-right: 0.5em; vertical-align: -0.15em;
			}
			@keyframes spin { to { transform: rotate(360deg); } }
			.stats-table { border-collapse: collapse; }
			.stats-table th, .stats-table td {
				border: 1px solid #ddd;
				padding: 0.3em 0.8em;
				text-align: center;
			}
			#save-status { font-weight: bold; }
			#save-status[data-state="error"] { color: #c62828; }
			#save-status[data-state="success"] { color: #2e7d32; }
		</style>
	</head>
	<body>
		<h1>育成ビルダー</h1>
		<p>
			<a href="/">トップへ戻る</a>
		</p>

		<section>
			<h2>1. 計算エンジンの読み込み</h2>
			<p>
				<button id="init-button" type="button">計算エンジンを読み込む</button>
			</p>
			<p id="engine-status" data-state="idle">未初期化(ボタンを押すまでPyodideはロードされません)</p>
		</section>

		<section>
			<h2>2. 育成入力</h2>
			<fieldset>
				<legend>基本情報</legend>
				<div class="row">
					<label for="pokemon-name">ポケモン名</label>
					<input id="pokemon-name" type="text" list="pokemon-list" autocomplete="off" />
				</div>
				<div class="row">
					<label for="nature">性格</label>
					<select id="nature">
						{NATURES.map((n) => <option value={n}>{n}</option>)}
					</select>
				</div>
				<div class="row">
					<label for="ability">特性</label>
					<input id="ability" type="text" list="ability-list" autocomplete="off" />
				</div>
				<div class="row">
					<label for="item">持ち物</label>
					<input id="item" type="text" list="item-list" autocomplete="off" />
				</div>
				<div class="row">
					<label for="tera">テラスタイプ</label>
					<select id="tera">
						<option value="">なし</option>
						{TERA_TYPES.map((t) => <option value={t}>{t}</option>)}
					</select>
				</div>
			</fieldset>

			<fieldset style="margin-top: 1rem;">
				<legend>努力値・個体値</legend>
				<div class="row stat-grid">
					<span class="stat-grid-label">努力値(0〜32)</span>
					<div class="stat-inputs">
						{STAT_LABELS.map(({ key, label: statLabel }) => (
							<label class="stat-input">
								{statLabel}
								<input id={`ev-${key}`} type="number" min="0" max="32" step="1" value="0" />
							</label>
						))}
					</div>
				</div>
				<div class="row stat-grid">
					<span class="stat-grid-label">個体値(省略可・既定31)</span>
					<div class="stat-inputs">
						{STAT_LABELS.map(({ key, label: statLabel }) => (
							<label class="stat-input">
								{statLabel}
								<input id={`iv-${key}`} type="number" min="0" max="31" step="1" placeholder="31" />
							</label>
						))}
					</div>
				</div>
			</fieldset>

			<fieldset style="margin-top: 1rem;">
				<legend>技構成(最大4つ・任意)</legend>
				<div class="move-inputs">
					{MOVE_SLOTS.map((slot) => (
						<input id={`move-${slot}`} type="text" list="move-list" autocomplete="off" placeholder={`技${slot}`} />
					))}
				</div>
			</fieldset>

			<datalist id="pokemon-list"></datalist>
			<datalist id="move-list"></datalist>
			<datalist id="ability-list"></datalist>
			<datalist id="item-list"></datalist>
		</section>

		<section>
			<h2>3. 実数値</h2>
			<table class="stats-table">
				<thead>
					<tr>
						{STAT_LABELS.map(({ label: statLabel }) => <th>{statLabel}</th>)}
					</tr>
				</thead>
				<tbody>
					<tr>
						{STAT_LABELS.map(({ key }) => <td id={`stat-${key}`}>(未計算)</td>)}
					</tr>
				</tbody>
			</table>
		</section>

		<section>
			<h2>4. 保存</h2>
			<p>
				<label>
					<input id="is-public" type="checkbox" checked />
					公開する(共有URLで誰でも閲覧可能にする)
				</label>
			</p>
			<p>
				<button id="save-button" type="button">保存する</button>
			</p>
			<p id="save-status">(未保存)</p>
		</section>

		<script>
			import {
				initEngine,
				calcStats,
				isEngineReady,
				registerOfflineCache,
				type EngineProgress,
				type PokemonSpec,
			} from "../../lib/pyodide-engine";

			const STAT_KEYS = ["hp", "atk", "def", "spa", "spd", "spe"] as const;
			const MOVE_SLOTS = [1, 2, 3, 4];

			function el<T extends HTMLElement>(id: string): T {
				const found = document.getElementById(id);
				if (!found) {
					throw new Error(`要素が見つかりません: #${id}`);
				}
				return found as T;
			}

			const initButton = el<HTMLButtonElement>("init-button");
			const statusEl = el<HTMLElement>("engine-status");
			const pokemonNameInput = el<HTMLInputElement>("pokemon-name");
			const saveButton = el<HTMLButtonElement>("save-button");
			const saveStatusEl = el<HTMLElement>("save-status");
			const isPublicInput = el<HTMLInputElement>("is-public");

			function renderProgress(progress: EngineProgress) {
				statusEl.dataset.state = progress.status;
				const spinner = progress.status === "loading" ? '<span class="spinner"></span>' : "";
				statusEl.innerHTML = spinner + progress.message;
				// エンジン初期化完了後、入力済みなら実数値をすぐに反映する
				if (progress.status === "ready") {
					void recalcStats();
				}
			}

			// --- オートコンプリート用の軽量JSON(build:master-data 生成物)を datalist に反映 ---
			async function loadAutocomplete() {
				try {
					const [pokemonRes, moveRes, abilityRes, itemRes] = await Promise.all([
						fetch("/master-data/autocomplete/pokemon.json"),
						fetch("/master-data/autocomplete/moves.json"),
						fetch("/master-data/autocomplete/abilities.json"),
						fetch("/master-data/autocomplete/items.json"),
					]);
					const fillDatalist = async (
						res: Response,
						datalistId: string,
					): Promise<void> => {
						const list = (await res.json()) as Array<{ name: string }>;
						const datalist = el<HTMLDataListElement>(datalistId);
						const fragment = document.createDocumentFragment();
						for (const { name } of list) {
							const option = document.createElement("option");
							option.value = name;
							fragment.appendChild(option);
						}
						datalist.appendChild(fragment);
					};
					await Promise.all([
						fillDatalist(pokemonRes, "pokemon-list"),
						fillDatalist(moveRes, "move-list"),
						fillDatalist(abilityRes, "ability-list"),
						fillDatalist(itemRes, "item-list"),
					]);
				} catch (err) {
					console.warn("オートコンプリート用データの読み込みに失敗しました", err);
				}
			}

			// --- フォーム値の読み取り ---
			function clamp(n: number, min: number, max: number): number {
				return Math.min(max, Math.max(min, Math.round(n)));
			}

			function readEv(stat: string): number {
				const raw = Number(el<HTMLInputElement>(`ev-${stat}`).value);
				if (!Number.isFinite(raw)) return 0;
				return clamp(raw, 0, 32);
			}

			function readIv(stat: string): number {
				const raw = el<HTMLInputElement>(`iv-${stat}`).value.trim();
				if (raw === "") return 31;
				const n = Number(raw);
				if (!Number.isFinite(n)) return 31;
				return clamp(n, 0, 31);
			}

			function readMoveNames(): string[] {
				return MOVE_SLOTS.map((slot) => el<HTMLInputElement>(`move-${slot}`).value.trim()).filter(
					(name) => name !== "",
				);
			}

			function buildSpec(): PokemonSpec {
				const name = pokemonNameInput.value.trim();
				const nature = el<HTMLSelectElement>("nature").value || undefined;
				const abilityName = el<HTMLInputElement>("ability").value.trim() || undefined;
				const itemName = el<HTMLInputElement>("item").value.trim() || undefined;
				const teraType = el<HTMLSelectElement>("tera").value || undefined;
				const evs = STAT_KEYS.map((stat) => readEv(stat));
				const ivs = STAT_KEYS.map((stat) => readIv(stat));
				const moveNames = readMoveNames();
				return { name, nature, abilityName, itemName, teraType, evs, ivs, moveNames };
			}

			// --- 実数値表示 ---
			function renderStatsUnavailable(): void {
				for (const key of STAT_KEYS) {
					el<HTMLElement>(`stat-${key}`).textContent = "(未計算)";
				}
			}

			async function recalcStats(): Promise<void> {
				const name = pokemonNameInput.value.trim();
				if (!name || !isEngineReady()) {
					renderStatsUnavailable();
					return;
				}
				try {
					const spec = buildSpec();
					const { stats } = await calcStats(spec);
					for (const key of STAT_KEYS) {
						el<HTMLElement>(`stat-${key}`).textContent = String(stats[key]);
					}
				} catch (err) {
					console.error(err);
					renderStatsUnavailable();
				}
			}

			// --- 保存 ---
			interface SaveResponseBody {
				data?: { id: string; share_slug: string };
				error?: string;
			}

			async function saveBuild(): Promise<void> {
				const name = pokemonNameInput.value.trim();
				if (!name) {
					saveStatusEl.dataset.state = "error";
					saveStatusEl.textContent = "ポケモン名を入力してください";
					return;
				}

				const spec = buildSpec();
				const nature = el<HTMLSelectElement>("nature").value || undefined;
				const teraType = el<HTMLSelectElement>("tera").value || undefined;

				saveButton.disabled = true;
				saveStatusEl.dataset.state = "";
				saveStatusEl.textContent = "保存中...";

				try {
					const res = await fetch("/api/builds", {
						method: "POST",
						credentials: "same-origin",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							pokemon_name: spec.name,
							nature,
							ability_name: spec.abilityName,
							item_name: spec.itemName,
							tera_type: teraType,
							evs: spec.evs,
							ivs: spec.ivs,
							move_names: spec.moveNames,
							is_public: isPublicInput.checked,
						}),
					});
					const body = (await res.json().catch(() => ({}))) as SaveResponseBody;
					if (!res.ok || !body.data) {
						throw new Error(body.error ?? `保存に失敗しました (status=${res.status})`);
					}
					saveStatusEl.dataset.state = "success";
					saveStatusEl.innerHTML = "";
					const link = document.createElement("a");
					link.href = `/builds/${body.data.share_slug}`;
					link.textContent = `保存しました。共有ページを見る: ${link.href}`;
					saveStatusEl.appendChild(link);
				} catch (err) {
					console.error(err);
					saveStatusEl.dataset.state = "error";
					saveStatusEl.textContent =
						"エラー: " + (err instanceof Error ? err.message : String(err));
				} finally {
					saveButton.disabled = false;
				}
			}

			// --- イベント配線 ---
			initButton.addEventListener("click", () => {
				// ここが唯一のPyodide初期化トリガー。ページ読み込み時には呼ばれない。
				initEngine(renderProgress).catch((err) => {
					console.error(err);
				});
			});

			// ステータスに影響する入力項目の変更のたびに実数値を再計算する。
			// input イベントまで細かく拾う必要はないため change イベントで十分。
			const statAffectingIds = [
				"pokemon-name",
				"nature",
				"ability",
				"item",
				"tera",
				...STAT_KEYS.map((k) => `ev-${k}`),
				...STAT_KEYS.map((k) => `iv-${k}`),
			];
			for (const id of statAffectingIds) {
				el<HTMLElement>(id).addEventListener("change", () => {
					void recalcStats();
				});
			}

			saveButton.addEventListener("click", () => {
				void saveBuild();
			});

			renderProgress({ status: "idle", message: "未初期化(ボタンを押すまでPyodideはロードされません)" });
			renderStatsUnavailable();
			void loadAutocomplete();
			// Pyodide自体のロードは開始しない(SW登録のみ)。2回目以降の訪問で
			// pyodide.js/wheelの再ダウンロードを避けるため、ページ読み込み時に登録しておく。
			registerOfflineCache();
		</script>
	</body>
</html>
